{% assign metafields = product.metafields %}

<input type="hidden" name="id" data-productid="{{ product.id }}" value="{{ product.selected_or_first_available_variant.id }}">

{% if metafields.mfr_fields.nice_title != blank %}
  <input type="hidden" name="properties[_nice_title]" value="{{ metafields.mfr_fields.nice_title }}">
{% endif %}

{% assign first_selling_plan_group = product.selling_plan_groups | first %}
{% assign first_selling_plan = first_selling_plan_group.selling_plans | first %}
{% assign first_selling_plan_id = first_selling_plan.id %}