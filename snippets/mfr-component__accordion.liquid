{%- comment -%}
  COMPONENT: Accordion
  ----------------------------------------------------------------------------
  USAGE:
    {% render 'mfr-component__accordion',
      trigger_label: "Accordion Title",
      initially_open: true,
      class: "optional-wrapper-class",
      trigger_class: ".optional-trigger-class",
      content_class: ".optional-content-class",
      content: content,
      accordion_parent: "optional-parent-class",
      avoid_multi_opened_accordion: false
    %}

  CONTENT EXAMPLE:
    <div class="prose">
      <p>This is the content inside the accordion. It can include any valid HTML.</p>
    </div>

  NOTES:
    - 'trigger_label' sets the accordion header text.
    - 'trigger_label_html' sets custom HTML for the trigger label (overrides trigger_label).
    - 'initially_open' (boolean) controls whether the accordion is open by default.
    - 'content' is required and defines the body content of the accordion.
    - Add `class`, `trigger_class`, or `content_class` for optional styling hooks.
    - Icon symbol (#icon-accordion-plus) must be rendered once per page via
      the icon__accordion-plus snippet (rotates 45° to form × when open).
{%- endcomment -%}
{%- assign block_id = block_id | replace: "-", " " | replace: "_", " " | camelcase -%}
{%- if content != blank -%}
  <div
    class="mfr-accordion {{ class }} flex flex-col items-stretch w-full [border-bottom:1.5px_dashed_currentColor]"
    :class='isOpen ? "is-active" : ""'
    x-data='{
      isOpen: {%- if initially_open -%}true{%- else -%}false{%- endif -%},
      parent: {% if accordion_parent != blank %}$el.closest("{{ accordion_parent }}"){% else %}null{% endif %},
      allowMultiOopenedAccordion: {{ allow_multiple_open_accordion | default: false }},
      closeAccordion() {
        this.isOpen = false
      },
      $accordion: $el
    }'
    data-inview>
    <button
      class="mfr-accordion__trigger {{ trigger_class }} flex items-center justify-between py-[0.875rem] gap-[1rem] select-none w-full"
      @click='
        if(parent && !allowMultiOopenedAccordion) {
          parent.querySelectorAll( ".mfr-accordion" ).forEach( (e) => {
            const alpineData = Alpine.$data(e);
            if($accordion != e) alpineData.closeAccordion();
          } );
        }
        isOpen = !isOpen
      '
      :aria-expanded="isOpen"
    >
      <div class="mfr-accordion__trigger-label [font-family:var(--custom-font-name-2)] text-[14px] font-[700] uppercase leading-[1.4] [color:var(--section-heading)] text-left">
        {%- if trigger_label_html != blank -%}
          {{ trigger_label_html }}
        {%- else -%}
          {{ trigger_label }}
        {%- endif -%}
      </div>

      <div class="mfr-accordion__toggle flex items-center justify-center w-[26px] h-[26px] border border-current shrink-0 rounded-full bg-[var(--color-white)]">
        <svg
          width="11"
          height="11"
          aria-hidden="true"
          focusable="false"
          class="transition-transform duration-[400ms] ease-[cubic-bezier(0.5,0,0,1)]"
          :class="isOpen ? 'rotate-45' : 'rotate-0'">
          <use href="#icon-accordion-plus"/>
        </svg>
      </div>
    </button>

    <div
      class="mfr-accordion__content {{ content_class }} overflow-hidden"
      x-show="isOpen"
      x-collapse
      x-cloak>
      <div class="mfr-accordion__content-inner [font-family:var(--custom-font-name-2)] text-[12px] font-[700] uppercase leading-[1.4] opacity-70 [color:var(--section-heading)] pb-[0.875rem]">
        {{ content }}
      </div>
    </div>
  </div>
{%- endif -%}
