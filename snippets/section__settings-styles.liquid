{% if section.settings.mobile_alignment == "left" %}
  {%- assign justify_content_mobile = "flex-start" -%}
  {%- assign text_align_mobile = "left" -%}
{%- elsif section.settings.mobile_alignment == "right" -%}
  {%- assign justify_content_mobile = "flex-end" -%}
  {%- assign text_align_mobile = "right" -%}
{%- else -%}
  {%- assign justify_content_mobile = "center" -%}
  {%- assign text_align_mobile = "center" -%}
{% endif %}

{% if section.settings.desktop_alignment == "left" %}
  {%- assign justify_content_desktop = "flex-start" -%}
  {%- assign text_align_desktop = "left" -%}
{%- elsif section.settings.desktop_alignment == "right" -%}
  {%- assign justify_content_desktop = "flex-end" -%}
  {%- assign text_align_desktop = "right" -%}
{%- else -%}
  {%- assign justify_content_desktop = "center" -%}
  {%- assign text_align_desktop = "center" -%}
{%- endif -%}

{%- if request.visual_preview_mode -%}
  {%- assign shopify_section = "" -%}
{%- else -%}
  {%- assign shopify_section = "shopify-section-" -%}
{%- endif -%}

<style>
  {%- if section.settings.mobile_alignment != blank -%}
    @media (max-width: 1023px) {
      #{{- shopify_section -}}{{ section.id }} .alignment-helper {
        --justify-content-mobile: {{ justify_content_mobile }};
        --text-align-mobile: {{ text_align_mobile }};
      }
    }
  {%- endif -%}
  {%- if section.settings.desktop_alignment != blank -%}
    @media (min-width: 1024px) {
      #{{- shopify_section -}}{{ section.id }} .alignment-helper {
        --justify-content-desktop: {{ justify_content_desktop }};
        --text-align-desktop: {{ text_align_desktop }};
      }
    }
  {%- endif -%}

  {%- if section.settings.margin_bottom_mobile != blank and section.settings.grid_gutter contains "grid-gutter-mobile" -%}
    @media (max-width: 1023px) {
      #{{- shopify_section -}}{{ section.id }} section {
        --section-bottom-margin-mobile: {{ section.settings.margin_bottom_mobile }}px;
      }
    }
  {%- endif -%}
  
  {%- if section.settings.margin_bottom_desktop != blank and section.settings.grid_gutter contains "grid-gutter-desktop" -%}
    @media (min-width: 1024px) {
      #{{- shopify_section -}}{{ section.id }} section {
        --section-bottom-margin-desktop: {{ section.settings.margin_bottom_desktop }}px;
      }
    }
  {%- endif -%}
</style>