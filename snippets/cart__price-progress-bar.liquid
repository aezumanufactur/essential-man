{% render 'renderer__color-scheme', name: "section", color_scheme: block.settings.color_scheme_progress_bar, selector: ".price-progress-bar" %}

{% if block.settings.price != 0 and block.settings.price != blank %}
	{% assign priceSetting = block.settings.price | times: '100' %}

	<div class="price-progress-bar w-full [background:var(--soft-stone,#d5d1c8)] px-[20px] py-[16px] flex flex-col gap-[8px]" x-data="{
		includeSubscription: true,
		productIds: [],
    collectionHandle: '{{ block.settings.collection.handle }}',
		requiredTotal: window.priceProgressBar.requiredTotal,
		runningTotal: 0,
    isAllProducts: {{ block.settings.enabled_to_all_products | default: false }},
    items: $store.cart.cartData.items,
		state: {
			success: false,
			percentage: 0,
			remaining: window.priceProgressBar.requiredTotal
		},

		init() {
			this.$watch('$store.cart.cartData.items', async data => {
        this.items = $store.cart.cartData.items;
				if (data !== null && data !== undefined) {
					await this.trackPriceProgress()
					this.trackPriceProgressSuccess()
					this.trackPriceProgressPercentage()
					this.trackPriceProgressRemaining()
				}
			})
			this.$watch('productIds', data => {
				if (data !== null && data !== undefined) {
					this.trackPriceProgressSuccess()
					this.trackPriceProgressPercentage()
					this.trackPriceProgressRemaining()
				}
			})
		},

		async trackPriceProgress() {
			let itemPrice = 0, total = 0

      await this.populateProductId();

			this.items.forEach((item, index) => {
				if (this.includeSubscription) {
					if (this.productIds.includes(item.product_id)) {
						itemPrice = item.quantity * item.price
						total += itemPrice
					}
				} else {
					if (typeof item.selling_plan_allocation === 'undefined' && (this.productIds.includes(item.product_id) || this.isAllProducts)) {
						itemPrice = item.quantity * item.price
						total += itemPrice
					}
				}
			})
			this.runningTotal = total
		},

		trackPriceProgressSuccess() {
			this.runningTotal >= this.requiredTotal ? this.state.success = true : this.state.success = false
		},

		trackPriceProgressPercentage() {
			this.state.percentage = `${(this.runningTotal / this.requiredTotal) * 100}%`
		},

		trackPriceProgressRemaining() {
			this.state.remaining = (this.requiredTotal - this.runningTotal) / 100
		},

    async fetchAllProducts(collectionHandle) {
      const allIds = [];
      let page = 1;
      let hasMore = true;

      while (hasMore) {
        const res = await fetch(`/collections/${collectionHandle}/products.json?page=${page}`);
        const data = await res.json();

        if (data.products && data.products.length > 0) {
          const ids = data.products.map(product => product.id);
          allIds.push(...ids);
          page++;

          if (data.products.length < 30) {
            hasMore = false;
          }
        } else {
          hasMore = false;
        }
      }

      return allIds;
    },

    async populateProductId() {
      if(this.productIds.length <= 0) {
        this.productIds = await this.fetchAllProducts(this.collectionHandle)
        return;
      }
      return;
    }
	}">
		<div class="price-progress-bar__label text-center [font-family:var(--font-body)] text-[12px] font-[700] leading-[1.4] uppercase [color:var(--carbon,#1e1b22)] [&_p]:m-0 [&_p]:text-inherit [&_p]:font-inherit [&_p]:leading-inherit [&_strong]:font-inherit">
			<div class="price-progress-bar__label-success" x-show="state.success">
				{{ block.settings.success_message }}
			</div>

			<div class="price-progress-bar__label-fail" x-show="!state.success">
				{%- capture price_element -%}
					<span class="quantity-progress-bar__quantity" x-text="state.remaining"></span>
				{%- endcapture -%}

				{{ block.settings.condition_label | replace: "[price]", price_element }}
			</div>
		</div>

		<div class="price-progress-bar__progress relative h-[6px] w-full overflow-hidden rounded-[10px]">
			<div class="progress-bar__track absolute inset-0 h-full w-full rounded-[inherit] [background:var(--warm-sand,#c4bfb3)]"></div>
			<div class="progress-bar__value absolute left-0 top-0 h-full w-0 rounded-[inherit] [background:var(--carbon,#1e1b22)] transition-all" :style="{ width: state.percentage }"></div>
		</div>

		<script>
			window.priceProgressBar = window.cartCondition || {}
			window.priceProgressBar.productIds = [
				{%- for condition_product in block.settings.collection.products -%}
					{{- condition_product.id -}}{% unless forloop.last %},{% endunless %}
				{%- endfor -%}
			]

			window.priceProgressBar.requiredTotal = Number({{- priceSetting -}})
		</script>
	</div>
{% endif %}
