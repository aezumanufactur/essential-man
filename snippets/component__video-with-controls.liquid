{% unless without_wrapper %}
  <div class="mfr-video-with-controls">
{% endunless %}
  <style>
    #shopify-block-{{ block_id }} .mfr-video-with-controls__inner {
      max-width: {{ block.settings.width_mobile }}px;
      aspect-ratio: {{ block.settings.aspect_ratio_mobile }};
    }
    @media (min-width: 1024px) {
      #shopify-block-{{ block_id }} .mfr-video-with-controls__inner {
        max-width: {{ block.settings.width_desktop }}px;
        aspect-ratio: {{ block.settings.aspect_ratio_desktop }};
      }
    }
  </style>
  {% assign video_ref = "video" | append: block_id %}
  {% render 'component__video',
    video: video,
    poster_size: poster_size,
    autoplay: autoplay,
    loop: loop,
    controls: controls,
    playsinline: true,
    muted: muted,
    video_ref: video_ref,
    poster_image: poster %}

  <div class="mfr-video-with-controls__controls">

    <div class="mfr-video-with-controls__indicator absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[50px] h-[50px] pointer-events-none large:w-[70px] large:h-[70px]"
      x-data='{
        paused: $refs["{{- video_ref -}}"].paused
      }'
      x-init='
        const handleEvent = (event) => {
          paused = $refs["{{- video_ref -}}"].paused;
        };

        // Add multiple event listeners using a loop
        ["play", "pause"].forEach(event => {
            $refs["{{- video_ref -}}"].addEventListener(event, handleEvent);
        });
      '
      x-transition:enter="transition-all duration-[400ms] ease-[cubic-bezier(0.5,0,0,1)]"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-1"
      x-transition:leave="transition-all duration-[400ms] ease-[cubic-bezier(0.5,0,0,1)]"
      x-transition:leave-start="opacity-1"
      x-transition:leave-end="opacity-0"
      x-show="paused">
      <svg width="31px" height="31px">
        <use href="#play-icon-v2">
      </svg>
    </div>

    {% if show_play_button != blank %}
      <button class="play-pause-button absolute top-[18px] right-[18px] w-[38px] h-[38px] z-[1] large:top-[20px] large:right-[20px] large:w-[46px] large:h-[46px] [&_svg]:w-full [&_svg]:h-auto [&_svg]:block"
        x-data='{
          paused: $refs["{{- video_ref -}}"].paused
        }'
        x-init='
          const handleEvent = (event) => {
            paused = $refs["{{- video_ref -}}"].paused;
          };

          // Add multiple event listeners using a loop
          ["play", "pause"].forEach(event => {
              $refs["{{- video_ref -}}"].addEventListener(event, handleEvent);
          });
        '
        x-transition:enter="transition-all duration-[400ms] ease-[cubic-bezier(0.5,0,0,1)]"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-1"
        x-transition:leave="transition-all duration-[400ms] ease-[cubic-bezier(0.5,0,0,1)]"
        x-transition:leave-start="opacity-1"
        x-transition:leave-end="opacity-0"
        :class='paused ? "play" : "pause"'
        aria-label="Play/Pause"
        @click="$refs['{{- video_ref -}}'].paused ? $refs['{{- video_ref -}}'].play() : $refs['{{- video_ref -}}'].pause()"
        x-show="!paused">
          
        <span class="play-pause-button__icon play">
          <svg width="31px" height="31px">
            <use href="#play-icon-v2">
          </svg>
        </span>
        <span class="play-pause-button__icon pause">
          <svg width="31px" height="31px">
            <use href="#pause-icon-v2">
          </svg>
        </span>
      </button>
    {% endif %}
    
    {% if show_speaker_button %}
      <button class="speaker-button absolute top-[23px] left-[23px] z-[1] large:top-[27px] large:left-[27px]" 
        x-data='{
          muted: $refs["{{- video_ref -}}"].muted
        }'
        x-init='
          $refs["{{- video_ref -}}"].onvolumechange = () => {
            muted = $refs["{{- video_ref -}}"].muted;
          };
        '
        :class='muted ? "mute" : "speaker"'
        @click="$refs['{{- video_ref -}}'].muted = !$refs['{{- video_ref -}}'].muted"
        aria-label="Toggle Sound">
        <span class="speaker-button__icon speaker text-[#EEECE5]">
          <svg width="31px" height="31px">
            <use href="#speaker-icon-v2">
          </svg>
        </span>
        <span class="speaker-button__icon mute text-[#EEECE5]">
          <svg width="31px" height="31px">
            <use href="#mute-icon-v2">
          </svg>
        </span>
      </button>
    {% endif %}

    {%- if show_indicator -%}
      <div class="mfr-video-with-controls__progress absolute bottom-0 left-0 w-full h-[3px] bg-white/20 z-[2]"
        x-data='{ progress: 0 }'
        x-init='
          const video = $refs["{{- video_ref -}}"];
          const update = () => {
            progress = video.duration ? (video.currentTime / video.duration) * 100 : 0;
          };
          video.addEventListener("timeupdate", update);
          video.addEventListener("loadedmetadata", update);
        '>
        <div class="mfr-video-with-controls__progress-fill h-full bg-white transition-[width] duration-100 ease-linear" :style='"width: " + progress + "%"'></div>
      </div>
    {%- endif -%}
  </div>
{% unless without_wrapper %}
</div>
{% endunless %}