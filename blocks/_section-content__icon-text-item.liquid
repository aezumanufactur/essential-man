{%- render "settings__block-layout-controls" -%}

{%- assign icon = block.settings.icon -%}
{%- assign title = block.settings.title -%}
{%- assign text = block.settings.text -%}
{%- assign title_style = block.settings.title_style -%}
{%- assign text_style = block.settings.text_style -%}
{%- assign title_width = block.settings.title_width -%}
{%- assign text_width = block.settings.text_width -%}
{% assign item_max_width_mobile = block.settings.item_max_width_mobile %}
{% assign item_max_width_desktop = block.settings.item_max_width_desktop %}
{% assign icon_render_width = block.settings.item_max_width_mobile %}
{% assign icon_width_mobile = block.settings.icon_width_mobile %}
{% assign icon_height_mobile = block.settings.icon_height_mobile %}
{% assign icon_width_desktop = block.settings.icon_width_desktop %}
{% assign icon_height_desktop = block.settings.icon_height_desktop %}
{% assign layout = block.settings.layout %}

{% if block.settings.item_max_width_desktop > block.settings.item_max_width_mobile %}
  {% assign icon_render_width = block.settings.item_max_width_desktop %}
{% endif %}

{%- if title != blank or text != blank -%}
  <style>
    #shopify-block-{{ block.id }} {
      --title-width: {{ title_width }}%;
      --text-width: {{ text_width }}%;
      {% if item_max_width_mobile != blank and item_max_width_mobile != 0 %}
        --item-max-width-mobile: {{ item_max_width_mobile }}px;
      {% endif %}
      {% if item_max_width_desktop != blank and item_max_width_desktop != 0 %}
        --item-max-width-desktop: {{ item_max_width_desktop }}px;
      {% endif %}
      --icon-width-mobile: {{ icon_width_mobile | default: 45 }}px;
      {%- if icon_height_mobile == 0 -%}
        --icon-height-mobile: auto;
      {%- else -%}
        --icon-height-mobile: {{ icon_height_mobile | default: 45 }}px;
      {%- endif -%}
      --icon-width-desktop: {{ icon_width_desktop | default: 90 }}px;
      {%- if icon_height_desktop == 0 -%}
        --icon-height-desktop: auto;
      {%- else -%}
        --icon-height-desktop: {{ icon_height_desktop | default: 90 }}px;
      {%- endif -%}
      {% if layout == "icon-left" %}
        --flex-direction: row;
        --align-items: center;
        --justify-content: stretch;
        --text-align: left;
      {%- else -%}
        --flex-direction: column;
        --align-items: center;
        --justify-content: flex-start;
        --text-align: center;
      {% endif %}
      --gap-mobile: {{ block.settings.gap_mobile | default: 12 }}px;
      --gap-desktop: {{ block.settings.gap_desktop | default: 12 }}px;

      {%- if block.settings.border_radius_mobile != 0 -%}
        --icon-border-radius-mobile: {{ block.settings.border_radius_mobile }}px;
      {%- endif -%}
      {%- if block.settings.border_radius_desktop != 0 -%}
        --icon-border-radius-desktop: {{ block.settings.border_radius_desktop }}px;
      {%- endif -%}
    }
  </style>
  <div class="section-icon-text__item-icon">
    {% render 'component__lazyload-image',
      image: icon,
      width: icon_render_width %}
  </div>
  <div class="section-icon-text__item-inner">
    {% if title != blank %}
      <p class="section-icon-text__item-title {{ title_style }}">
        {{ title }}
      </p>
    {% endif %}
    {% if text != blank %}
      <p class="section-icon-text__item-text {{ text_style }}">
        {{ text }}
      </p>
    {% endif %}
  </div>
{%- endif -%}

