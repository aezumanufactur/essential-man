{% assign icon = block.settings.icon %}
{% assign lottie_file_url = block.settings.file_lottie_url %}

{%- capture sizes -%}
  min(100vw,{{ block.settings.icon_width_mobile }}px),
  (min-width: 1024px) min(100vw,{{ block.settings.icon_width_desktop }}px)
{%- endcapture -%}

{% assign width = block.settings.icon_width_desktop %}
{% if block.settings.icon_width_mobile > block.settings.icon_width_desktop %}
  {% assign width = block.settings.icon_width_mobile %}
{% endif %}

{%- render "settings__block-layout-controls" -%}

<div class="section-icon inline-flex items-center w-full">
{% if lottie_file_url != blank %}
    <lottie-player src="{{ lottie_file_url }}"
      background="transparent"
      speed="0.5"
      loop
      autoplay>
    </lottie-player>
{% else %}
  {% if icon %}
    {% render 'component__lazyload-image',
      image: icon,
      alt: icon,
      width: width,
      sizes: sizes %}
  {% else %}
      <div class="shopify-placeholder-image">{{ 'image' | placeholder_svg_tag }}</div>
  {% endif %}
{% endif %}
</div>

