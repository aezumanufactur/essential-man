{%- assign ar_mobile = block.settings.aspect_ratio_mobile_custom | default: block.settings.aspect_ratio_mobile -%}
{%- assign ar_desktop = block.settings.aspect_ratio_desktop_custom | default: block.settings.aspect_ratio_desktop -%}

{%- render "settings__block-layout-controls" -%}

<div class="text-icon-card-grid__card__inner aspect-[{{ ar_mobile }}] large:aspect-[{{ ar_desktop }}] border border-[color:var(--section-heading)] flex flex-col justify-between">

  {%- if block.settings.title != blank -%}
    <p class="text-icon-card-grid__card__title [font-family:var(--font-heading-h4)] text-[20px] large:text-[26px] font-[500] leading-[1.1] uppercase [color:var(--section-heading)]">
      {{ block.settings.title }}
    </p>
  {%- endif -%}

  <div class="text-icon-card-grid__card__footer flex flex-col gap-[8px]">
    {%- if block.settings.icon != blank -%}
      <div class="text-icon-card-grid__card__icon-wrap size-[60px] large:size-[75px]">
        {%- render 'component__lazyload-image',
          image: block.settings.icon,
          width: 150,
          class: "w-full h-auto block" -%}
      </div>
    {%- endif -%}

    {%- if block.settings.description != blank -%}
      <p class="text-icon-card-grid__card__description [font-family:var(--custom-font-name-2)] text-[12px] large:text-[14px] font-[700] leading-[1.4] large:leading-[20px] uppercase opacity-70 [color:var(--section-heading)]">
        {{ block.settings.description }}
      </p>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Card",
  "class": "text-icon-card-grid__card",
  "settings": [
    {
      "type": "header",
      "content": "Card Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Aspect Ratio Settings"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Aspect Ratio - Mobile",
      "options": [
        { "value": "9/16", "label": "9:16 (Portrait)" },
        { "value": "3/4", "label": "3:4" },
        { "value": "2/3", "label": "2:3" },
        { "value": "1/1", "label": "1:1 (Square)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "16/9", "label": "16:9 (Landscape)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "3/4"
    },
    {
      "type": "text",
      "id": "aspect_ratio_mobile_custom",
      "label": "Custom Aspect Ratio - Mobile",
      "info": "Format: width/height e.g. 195/260",
      "visible_if": "{{ block.settings.aspect_ratio_mobile == 'custom' }}"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Aspect Ratio - Desktop",
      "options": [
        { "value": "9/16", "label": "9:16 (Portrait)" },
        { "value": "1/1", "label": "1:1 (Square)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "3/2", "label": "3:2" },
        { "value": "16/9", "label": "16:9 (Landscape)" },
        { "value": "21/9", "label": "21:9 (Ultrawide)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "9/16"
    },
    {
      "type": "text",
      "id": "aspect_ratio_desktop_custom",
      "label": "Custom Aspect Ratio - Desktop",
      "info": "Format: width/height e.g. 260/420",
      "visible_if": "{{ block.settings.aspect_ratio_desktop == 'custom' }}"
    },
    {
      "type": "header",
      "content": "Block Layout Controls"
    },
    {
      "type": "paragraph",
      "content": "Width Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_width_settings",
      "label": "Enable Width Settings",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "width_mobile",
      "label": "Width - Mobile",
      "default": false,
      "visible_if": "{{ block.settings.enable_width_settings }}"
    },
    {
      "type": "number",
      "id": "width_mobile_value",
      "label": "Width Value - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit != 'custom' }}"
    },
    {
      "type": "text",
      "id": "width_mobile_custom",
      "label": "Width Custom - Mobile",
      "info": "Use this for custom values or calculations like calc(100% / 3).",
      "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile_unit",
      "label": "Width Unit - Mobile",
      "options": [
        { "value": "px", "label": "Pixels (px)" },
        { "value": "%", "label": "Percent (%)" },
        { "value": "vw", "label": "Viewport Width (vw)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "px",
      "visible_if": "{{ block.settings.width_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "width_desktop",
      "label": "Width - Desktop",
      "default": false,
      "visible_if": "{{ block.settings.enable_width_settings }}"
    },
    {
      "type": "number",
      "id": "width_desktop_value",
      "label": "Width Value - Desktop",
      "default": 0,
      "visible_if": "{{ block.settings.width_desktop and block.settings.width_desktop_unit != 'custom' }}"
    },
    {
      "type": "text",
      "id": "width_desktop_custom",
      "label": "Width Custom - Desktop",
      "info": "Use this for custom values or calculations like calc(100% / 3).",
      "visible_if": "{{ block.settings.width_desktop and block.settings.width_desktop_unit == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_desktop_unit",
      "label": "Width Unit - Desktop",
      "options": [
        { "value": "px", "label": "Pixels (px)" },
        { "value": "%", "label": "Percent (%)" },
        { "value": "vw", "label": "Viewport Width (vw)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "px",
      "visible_if": "{{ block.settings.width_desktop }}"
    },
    {
      "type": "paragraph",
      "content": "Padding Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_padding_settings",
      "label": "Enable Padding Settings",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "padding_x_mobile",
      "label": "Padding X - Mobile",
      "default": false,
      "visible_if": "{{ block.settings.enable_padding_settings }}"
    },
    {
      "type": "number",
      "id": "padding_left_mobile",
      "label": "Padding Left - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.padding_x_mobile }}"
    },
    {
      "type": "number",
      "id": "padding_right_mobile",
      "label": "Padding Right - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.padding_x_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "padding_y_mobile",
      "label": "Padding Y - Mobile",
      "default": false,
      "visible_if": "{{ block.settings.enable_padding_settings }}"
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "Padding Top - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.padding_y_mobile }}"
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.padding_y_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "padding_x_desktop",
      "label": "Padding X - Desktop",
      "default": false,
      "visible_if": "{{ block.settings.enable_padding_settings }}"
    },
    {
      "type": "number",
      "id": "padding_left_desktop",
      "label": "Padding Left - Desktop",
      "default": 0,
      "visible_if": "{{ block.settings.padding_x_desktop }}"
    },
    {
      "type": "number",
      "id": "padding_right_desktop",
      "label": "Padding Right - Desktop",
      "default": 0,
      "visible_if": "{{ block.settings.padding_x_desktop }}"
    },
    {
      "type": "checkbox",
      "id": "padding_y_desktop",
      "label": "Padding Y - Desktop",
      "default": false,
      "visible_if": "{{ block.settings.enable_padding_settings }}"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "Padding Top - Desktop",
      "default": 0,
      "visible_if": "{{ block.settings.padding_y_desktop }}"
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom - Desktop",
      "default": 0,
      "visible_if": "{{ block.settings.padding_y_desktop }}"
    },
    {
      "type": "paragraph",
      "content": "Margin Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_margin_settings",
      "label": "Enable Margin Settings",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "margin_x_mobile",
      "label": "Margin X - Mobile",
      "default": false,
      "visible_if": "{{ block.settings.enable_margin_settings }}"
    },
    {
      "type": "number",
      "id": "margin_left_mobile",
      "label": "Margin Left - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.margin_x_mobile }}"
    },
    {
      "type": "number",
      "id": "margin_right_mobile",
      "label": "Margin Right - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.margin_x_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "margin_y_mobile",
      "label": "Margin Y - Mobile",
      "default": false,
      "visible_if": "{{ block.settings.enable_margin_settings }}"
    },
    {
      "type": "number",
      "id": "margin_top_mobile",
      "label": "Margin Top - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.margin_y_mobile }}"
    },
    {
      "type": "number",
      "id": "margin_bottom_mobile",
      "label": "Margin Bottom - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.margin_y_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "margin_x_desktop",
      "label": "Margin X - Desktop",
      "default": false,
      "visible_if": "{{ block.settings.enable_margin_settings }}"
    },
    {
      "type": "number",
      "id": "margin_left_desktop",
      "label": "Margin Left - Desktop",
      "default": 0,
      "visible_if": "{{ block.settings.margin_x_desktop }}"
    },
    {
      "type": "number",
      "id": "margin_right_desktop",
      "label": "Margin Right - Desktop",
      "default": 0,
      "visible_if": "{{ block.settings.margin_x_desktop }}"
    },
    {
      "type": "checkbox",
      "id": "margin_y_desktop",
