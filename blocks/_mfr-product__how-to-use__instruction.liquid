{%- render 'settings__block-layout-controls' -%}

<div class="instruction">
  <div class="instruction__inner flex flex-col gap-[18px]">

    <div class="instruction__image-wrap aspect-[390/340] large:aspect-[322/380] w-full overflow-hidden border border-[var(--color-black)]">
      {%- if block.settings.image != blank -%}
        {%- assign alt = block.settings.image.alt | default: block.settings.title -%}
        {%- render 'component__lazyload-image',
          image: block.settings.image,
          width: 800,
          alt: alt,
          class: "w-full min-h-full block object-cover" -%}
      {%- else -%}
        <div class="w-full h-full bg-[#d9d9d9]"></div>
      {%- endif -%}
    </div>

    <div class="instruction__text flex flex-col gap-[16px] uppercase [color:var(--section-heading)]">
      <div class="instruction__header [font-family:var(--font-heading-h4)] text-[20px] large:text-[26px] font-[500] leading-[1.1] flex items-center justify-between">
        {%- if block.settings.title != blank -%}
          <div class="instruction__title"><p>{{ block.settings.title }}</p></div>
        {%- endif -%}
        {%- if block.settings.number != blank -%}
          <div class="instruction__number"><p>{{ block.settings.number }}</p></div>
        {%- endif -%}
      </div>
      {%- if block.settings.caption != blank -%}
        <div class="instruction__caption [font-family:var(--custom-font-name-2)] text-[14px] font-[700] leading-[1.4] large:leading-[1.5]"><p>{{ block.settings.caption }}</p></div>
      {%- endif -%}
    </div>

  </div>
</div>

