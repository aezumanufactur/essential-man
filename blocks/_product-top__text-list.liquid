{%- render "settings__block-layout-controls" -%}
{%- render "icon__checkmark" -%}

{%- assign list_ns = block.settings.metafield_namespace -%}
{%- assign list_key = block.settings.metafield_key -%}
{%- assign list_metafield = product.metafields[list_ns][list_key] -%}

<div class="product-top__text-list">
  <div class="product-top__text-list__inner flex flex-col gap-[13px] w-full">
    {%- for item in list_metafield.value -%}
      <div class="product-top__text-list__item flex flex-col gap-[12px] w-full">
        <div class="product-top__text-list__row flex flex-row gap-[12px] items-center w-full">
          <svg class="product-top__text-list__icon size-[19px] shrink-0" aria-hidden="true">
            <use href="#checkmark-icon"></use>
          </svg>
          <div class="product-top__text-list__text [font-family:var(--font-body)] text-[14px] font-[700] leading-[1.4] uppercase">
            <p>{{ item }}</p>
          </div>
        </div>
        {%- unless forloop.last -%}
          <div class="product-top__text-list__divider w-full h-px bg-current opacity-20"></div>
        {%- endunless -%}
      </div>
    {%- endfor -%}
  </div>
</div>

