{%- render 'settings__block-layout-controls' -%}
<style>
  {%- if block.settings.enable_border_mobile -%}
    {%- assign border_color_mobile = block.settings.border_opacity_mobile | append: '%, transparent)' | prepend: 'color-mix(in srgb, currentColor ' -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} {
        {%- if block.settings.border_top_mobile -%}border-top: 1px solid {{ border_color_mobile }};{%- endif -%}
        {%- if block.settings.border_right_mobile -%}border-right: 1px solid {{ border_color_mobile }};{%- endif -%}
        {%- if block.settings.border_bottom_mobile -%}border-bottom: 1px solid {{ border_color_mobile }};{%- endif -%}
        {%- if block.settings.border_left_mobile -%}border-left: 1px solid {{ border_color_mobile }};{%- endif -%}
      }
    }
  {%- endif -%}

  {%- if block.settings.enable_border_desktop -%}
    {%- assign border_color_desktop = block.settings.border_opacity_desktop | append: '%, transparent)' | prepend: 'color-mix(in srgb, currentColor ' -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} {
        {%- if block.settings.border_top_desktop -%}border-top: 1px solid {{ border_color_desktop }};{%- endif -%}
        {%- if block.settings.border_right_desktop -%}border-right: 1px solid {{ border_color_desktop }};{%- endif -%}
        {%- if block.settings.border_bottom_desktop -%}border-bottom: 1px solid {{ border_color_desktop }};{%- endif -%}
        {%- if block.settings.border_left_desktop -%}border-left: 1px solid {{ border_color_desktop }};{%- endif -%}
      }
    }
  {%- endif -%}

  {%- if block.settings.align_horizontal_mobile != blank or block.settings.align_vertical_mobile != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} > .footer__column__inner {
        {%- if block.settings.direction_mobile == "row" -%}
          {%- if block.settings.align_horizontal_mobile != blank -%}justify-content: {{ block.settings.align_horizontal_mobile }};{%- endif -%}
          {%- if block.settings.align_vertical_mobile != blank -%}align-items: {{ block.settings.align_vertical_mobile }};{%- endif -%}
        {%- else -%}
          {%- if block.settings.align_horizontal_mobile != blank -%}align-items: {{ block.settings.align_horizontal_mobile }};{%- endif -%}
          {%- if block.settings.align_vertical_mobile != blank -%}justify-content: {{ block.settings.align_vertical_mobile }};{%- endif -%}
        {%- endif -%}
      }
    }
  {%- endif -%}

  {%- if block.settings.align_horizontal_desktop != blank or block.settings.align_vertical_desktop != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} > .footer__column__inner {
        {%- if block.settings.direction_desktop == "row" -%}
          {%- if block.settings.align_horizontal_desktop != blank -%}justify-content: {{ block.settings.align_horizontal_desktop }};{%- endif -%}
          {%- if block.settings.align_vertical_desktop != blank -%}align-items: {{ block.settings.align_vertical_desktop }};{%- endif -%}
        {%- else -%}
          {%- if block.settings.align_horizontal_desktop != blank -%}align-items: {{ block.settings.align_horizontal_desktop }};{%- endif -%}
          {%- if block.settings.align_vertical_desktop != blank -%}justify-content: {{ block.settings.align_vertical_desktop }};{%- endif -%}
        {%- endif -%}
      }
    }
  {%- endif -%}

  {%- if block.settings.direction_mobile != "column" or block.settings.direction_desktop != "column" -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} > .footer__column__inner {
        flex-direction: {{ block.settings.direction_mobile | default: "column" }};
        flex-wrap: wrap;
      }
    }
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} > .footer__column__inner {
        flex-direction: {{ block.settings.direction_desktop | default: "column" }};
        flex-wrap: wrap;
      }
    }
  {%- endif -%}

  {%- if block.settings.visibility == 'mobile' -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} { display: none !important; }
    }
  {%- elsif block.settings.visibility == 'desktop' -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} { display: none !important; }
    }
  {%- endif -%}

  {%- if block.settings.enable_grid_container -%}
    #shopify-block-{{ block.id }} > .footer__column__inner {
      margin-left: auto;
      margin-right: auto;
      max-width: var(--grid-container-max-width);
      padding-left: var(--grid-container-padding-mobile);
      padding-right: var(--grid-container-padding-mobile);
    }
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} > .footer__column__inner {
        padding-left: var(--grid-container-padding-desktop);
        padding-right: var(--grid-container-padding-desktop);
      }
    }
  {%- endif -%}
</style>
<div class="footer__column__inner flex flex-col w-full">
  {%- content_for "blocks" -%}
</div>

