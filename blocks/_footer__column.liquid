{%- render 'settings__block-layout-controls' -%}
<style>
  {%- if block.settings.enable_border_mobile -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} {
        {%- if block.settings.border_top_mobile -%}border-top: 1px solid currentColor;{%- endif -%}
        {%- if block.settings.border_right_mobile -%}border-right: 1px solid currentColor;{%- endif -%}
        {%- if block.settings.border_bottom_mobile -%}border-bottom: 1px solid currentColor;{%- endif -%}
        {%- if block.settings.border_left_mobile -%}border-left: 1px solid currentColor;{%- endif -%}
      }
    }
  {%- endif -%}

  {%- if block.settings.enable_border_desktop -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} {
        {%- if block.settings.border_top_desktop -%}border-top: 1px solid currentColor;{%- endif -%}
        {%- if block.settings.border_right_desktop -%}border-right: 1px solid currentColor;{%- endif -%}
        {%- if block.settings.border_bottom_desktop -%}border-bottom: 1px solid currentColor;{%- endif -%}
        {%- if block.settings.border_left_desktop -%}border-left: 1px solid currentColor;{%- endif -%}
      }
    }
  {%- endif -%}

  {%- if block.settings.align_horizontal_mobile != blank or block.settings.align_vertical_mobile != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} .footer__column__inner {
        {%- if block.settings.align_horizontal_mobile != blank -%}
          align-items: {{ block.settings.align_horizontal_mobile }};
        {%- endif -%}
        {%- if block.settings.align_vertical_mobile != blank -%}
          justify-content: {{ block.settings.align_vertical_mobile }};
        {%- endif -%}
      }
    }
  {%- endif -%}

  {%- if block.settings.align_horizontal_desktop != blank or block.settings.align_vertical_desktop != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} .footer__column__inner {
        {%- if block.settings.align_horizontal_desktop != blank -%}
          align-items: {{ block.settings.align_horizontal_desktop }};
        {%- endif -%}
        {%- if block.settings.align_vertical_desktop != blank -%}
          justify-content: {{ block.settings.align_vertical_desktop }};
        {%- endif -%}
      }
    }
  {%- endif -%}
</style>
<div class="footer__column__inner flex flex-col w-full">
  {%- content_for "blocks" -%}
</div>

