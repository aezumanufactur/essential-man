{%- render "settings__block-layout-controls" -%}

<div class="product-top__images w-full">
  <div class="product-top__images__inner">

    {{- comment -}} Mobile carousel {{- endcomment -}}
    <div class="product-top__images-carousel-wrap large:hidden">
      {%- render 'product-top__images-carousel',
        product: product,
        section: section -%}
    </div>

    {{- comment -}} Desktop image grid {{- endcomment -}}
    <div class="product-top__images-grid hidden large:flex flex-wrap w-full">
      {%- for media in product.media -%}
        <div class="product-top__images-item w-full [&:nth-child(3n+2)]:w-1/2 [&:nth-child(3n)]:w-1/2 aspect-[4/5] [&:nth-child(3n+2)]:aspect-[1/1] [&:nth-child(3n)]:aspect-[1/1] overflow-hidden">
          {%- if media.media_type == 'image' -%}
            {%- render "component__lazyload-image",
              image: media.preview_image,
              width: 1200,
              class: "w-full min-h-full block object-cover" -%}
          {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
            <div class="w-full h-full">
              {{- media | media_tag: class: "w-full h-full object-cover", autoplay: false -}}
            </div>
          {%- else -%}
            {%- render "component__lazyload-image",
              image: media.preview_image,
              width: 1200,
              class: "w-full min-h-full block object-cover" -%}
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="product-top__images-item w-full aspect-[4/5] overflow-hidden bg-gray-100">
        </div>
      {%- endfor -%}
    </div>

    {%- if product.options_with_values.size > 0 -%}
      <div class="product-top__images-pills flex flex-wrap gap-[8px] px-5 py-[12px] large:px-0">
        {%- for value in product.options_with_values[0].values -%}
          <div class="product-top__images-pill [font-family:var(--font-body)] text-[12px] font-[700] leading-[20px] uppercase rounded-[5px] px-[8px] py-[4px] border border-current">
            <span>{{ value }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

