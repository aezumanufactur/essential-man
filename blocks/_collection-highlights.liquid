{%- if block.settings.product_highlights != blank -%}
  <div class="collection-highlight__inner carousel w-full"
    data-stagger-inview=".collection-highlight__entry"
    data-mfr-carousel="
    {
      prevNextButtons: false,
      contain: true,
      cellAlign: 'center',
      pageDots: true,
      wrapAround: false,
      groupCells: false,
      carouselOn: 'mobile'
    }
  ">
    <div class="collection-highlight__carousel carousel__slides">
      {% for entry in block.settings.product_highlights %}
        <div class="collection-highlight__entry carousel__item w-full max-w-[19.625rem] shrink-0 [color:var(--color-black)] py-0 px-[0.5rem] text-left large:w-[calc(100%/3)] large:max-w-none large:px-[0.6875rem] first:pl-[1.375rem] large:first:pl-[0.6875rem] last:pr-[1.375rem] large:last:pr-[0.6875rem]">
          <div class="collection-highlight__entry-inner">
            {% if entry.image != blank %}
              <div class="collection-highlight__entry-image w-full aspect-[314/318] flex items-stretch overflow-hidden rounded-[1.25rem] [&:not(:last-child)]:mb-[0.9375rem] large:[&:not(:last-child)]:mb-[1.75rem]" data-image-parallax>
                {% assign default_alt = "maybe an image about " | append: entry.title %}
                {% assign alt = entry.image.alt | default: default_alt %}
                {% render 'component__lazyload-image',
                  image: entry.image,
                  width: 720,
                  widths: "420,480,600,720",
                  alt: alt %}
              </div>
            {% endif %}

            {% if entry.title != blank %}
              <p class="collection-highlight__entry-title text-[1.5rem] leading-[1em] font-semibold tracking-[-0.02875rem] m-0 [color:currentColor] large:w-[70%] [&:not(:last-child)]:mb-[0.625rem]">
                {{ entry.title }}
              </p>
            {% endif %}
            {% if entry.caption != blank %}
              <p class="collection-highlight__entry-caption leading-[1.333em] font-normal tracking-[-0.0125rem] m-0 [color:currentColor] opacity-80 large:w-[71%]">
                {{ entry.caption }}
              </p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{%- elsif request.design_mode -%}
  <div class="collection-highlight__inner carousel w-full"
    data-stagger-inview=".collection-highlight__entry"
    data-mfr-carousel="
    {
      prevNextButtons: false,
      contain: true,
      cellAlign: 'center',
      pageDots: true,
      wrapAround: false,
      groupCells: false,
      carouselOn: 'mobile'
    }
  ">
    <div class="collection-highlight__carousel carousel__slides">
      {% for entry in (1..3) %}
        <div class="collection-highlight__entry carousel__item w-full max-w-[19.625rem] shrink-0 [color:var(--color-black)] py-0 px-[0.5rem] text-left large:w-[calc(100%/3)] large:max-w-none large:px-[0.6875rem] first:pl-[1.375rem] large:first:pl-[0.6875rem] last:pr-[1.375rem] large:last:pr-[0.6875rem]">
          <div class="collection-highlight__entry-inner">
            <div class="collection-highlight__entry-image w-full aspect-[314/318] flex items-stretch overflow-hidden rounded-[1.25rem] [&:not(:last-child)]:mb-[0.9375rem] large:[&:not(:last-child)]:mb-[1.75rem]">
              {% render 'component__lazyload-image',
                image: false,
                width: 720,
                widths: "420,480,600,720",
                alt: alt %}
            </div>

            <p class="collection-highlight__entry-title">
              Lorem, ipsum dolor.
            </p>
            <p class="collection-highlight__entry-caption">
              Lorem ipsum dolor sit amet consectetur adipisicing elit. Quo, rerum.
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
{%- endif -%}
{%- schema -%}
  {
    "name": "Collection Highlight",
    "class": "collection-highlight",
    "settings": [
      {
        "type": "metaobject_list",
        "id": "product_highlights",
        "label": "Product Highlight",
        "metaobject_type": "product_highlights"
      }
    ],
    "presets": [
      {
        "name": "Collection Highlight"
      }
    ]
  }
{%- endschema -%}
