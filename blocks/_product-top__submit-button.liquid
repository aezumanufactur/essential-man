{%- assign product_form_id = "product-form-" | append: product.id -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

{%- liquid
  assign check_against_inventory = true
  if current_variant.inventory_management != 'shopify' or current_variant.inventory_policy == 'continue'
    assign check_against_inventory = false
  endif
  if current_variant.quantity_rule.min > current_variant.inventory_quantity and check_against_inventory
    assign quantity_rule_soldout = true
  endif
-%}

{%- if current_variant.available -%}
  {%- assign open_off_canvas = 'x-data x-on:click="$store[`offCanvasCart`].openOffcanvas(); $store[`offCanvasProductForm`].closeOffcanvas()"' -%}
{%- else -%}
  {%- assign open_off_canvas = '' -%}
{%- endif -%}

{%- render "settings__block-layout-controls" -%}

<div
  class="product-top__submit-button w-full"
  data-replace="{{ section.id }}-{{ block.id }}-actions">

  <div class="product-top__submit-button__inner">
    {%- form 'product',
      product,
      id: product_form_id,
      class: 'form',
      novalidate: 'novalidate',
      data-type: 'add-to-cart-form',
      x-data: 'MFRProductForm()'
    -%}
      {%- render 'product-form__hidden-input', product: product -%}

      <div class="product-top__submit flex flex-col items-stretch justify-start gap-[0.5625rem] grow w-full">
        <button
          class="button add-to-cart primary [font-family:var(--font-heading-h2)] text-[15px] font-[500] uppercase leading-[36px] w-full rounded-[5px] px-5 py-2.5"
          type="submit"
          data-inview
          {%- if current_variant.available == false or quantity_rule_soldout or current_variant == null -%}
            disabled
          {%- endif -%}
          {{ open_off_canvas }}>
          {%- if current_variant == null -%}
            {{ block.settings.unavailable_label | default: "Unavailable" }}
          {%- elsif current_variant.available == false or quantity_rule_soldout -%}
            {{ block.settings.sold_out_label | default: "Sold Out" }}
          {%- else -%}
            <span class="product-top__submit-inner">
              {{ block.settings.add_to_cart_label | default: "Add To Cart" }}
              {%- if block.settings.show_price -%}
                <span class="separator">&mdash;</span>
                <span class="price">
                  <template x-if='currentCompareAtPrice'>
                    <span class="compare-at-price"
                      x-text='currentCompareAtPrice'></span>
                  </template>
                  <span class="original-price"
                    x-text='currentPriceValue'>
                    {{- current_variant.price | money_without_trailing_zeros -}}
                  </span>
                </span>
              {%- endif -%}
            </span>
          {%- endif -%}
        </button>

        {%- if block.settings.bottom_caption != blank -%}
          <div class="product-top__submit-caption [font-family:var(--font-body)] text-[12px] font-[700] leading-[1.5] uppercase opacity-60">
            <p>{{ block.settings.bottom_caption }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endform -%}

    {%- render 'script__section', file: "MFRProductForm.js" -%}
  </div>

</div>

