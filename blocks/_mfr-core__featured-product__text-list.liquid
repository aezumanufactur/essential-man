{%- render "settings__block-layout-controls" -%}

<div class="text-list">
  <div class="text-list__inner flex flex-col gap-[12px]">

    <div class="text-list__item flex items-center gap-[12px]">
      <div class="text-list__icon relative shrink-0 size-[19px]">
        <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="9.5" cy="9.5" r="9" stroke="currentColor" stroke-width="1"/>
          <path d="M6.5 9.5L8.5 11.5L12.5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="text-list__text [font-family:var(--font-body)] text-[14px] font-[700] leading-[18px] uppercase [color:var(--section-heading)] min-w-0 flex-1"><p>{{- block.settings.value -}}</p></div>
    </div>

    {%- if block.settings.show_divider -%}
      <div class="text-list__divider w-full border-t border-[var(--carbon,#1e1b22)] opacity-20"></div>
    {%- endif -%}

  </div>
</div>


{% schema %}
{
  "name": "Text List",
  "class": "text-list",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Metafield Handle",
      "default": "mfr_fields.benefit_1",
      "info": "Namespace and key of the product metafield (e.g. mfr_fields.benefit_1). Use dynamic source to pull value from the product."
    },
    {
      "type": "text",
      "id": "value",
      "label": "Display Text",
      "default": "Lorem ipsum dolor sit amet consectetur",
      "info": "Text shown for this list item. Replace with dynamic source after assigning product."
    },
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Divider Line",
      "default": true,
      "info": "Disable on the last item in the list."
    },
    {
      "type": "header",
      "content": "Block Layout Controls"
    },
    {
      "type": "paragraph",
      "content": "Width Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_width_settings",
      "label": "Enable Width Settings",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "width_mobile",
      "label": "Width - Mobile",
      "default": false,
      "visible_if": "{{ block.settings.enable_width_settings }}"
    },
    {
      "type": "number",
      "id": "width_mobile_value",
      "label": "Width Value - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit != 'custom' }}"
    },
    {
      "type": "text",
      "id": "width_mobile_custom",
      "label": "Width Custom - Mobile",
      "info": "Use this for custom values or calculations like calc(100% / 3).",
      "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile_unit",
      "label": "Width Unit - Mobile",
      "options": [
        { "value": "px", "label": "Pixels (px)" },
        { "value": "%", "label": "Percent (%)" },
        { "value": "vw", "label": "Viewport Width (vw)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "px",
      "visible_if": "{{ block.settings.width_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "width_desktop",
      "label": "Width - Desktop",
      "default": false,
