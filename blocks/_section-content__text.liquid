      },
      {
        "type": "select",
        "id": "width_desktop_unit",
        "label": "Width Unit - Desktop",
        "options": [
          { "value": "px", "label": "Pixels (px)" },
          { "value": "%", "label": "Percent (%)" },
          { "value": "vw", "label": "Viewport Width (vw)" },
          { "value": "custom", "label": "Custom" }
        ],
