{% comment %}
    Attributes

    - text
    - color
    - bold_color
    - text_style
    - font_family
    - shopify_attributes
{% endcomment %}

{% assign color = block.settings.color %}
{% assign text = block.settings.text %}
{% assign text_style = block.settings.text_style %}
{% assign highlight_color = block.settings.highlight_color %}
{% assign underline_color = block.settings.underline_color %}
{% assign disable_animation = block.settings.disable_animation %}
{% assign custom_font = block.settings.font_family %}

{% if color != "" and color != "rgba(0,0,0,0)" %}
  {% assign has_custom_color = "has-custom-color" %}
  {% assign color_style = "color: " | append: color | append: ";" %}
{% else %}
  {% assign has_custom_color = "" %}
  {% assign color_style = "" %}
{% endif %}

{% if underline_color != "" and underline_color != "rgba(0,0,0,0)" %}
  {% assign has_underline_class = "has-underline" %}
{% else %}
  {% assign has_underline_class = "" %}
{% endif %}

<style>
  #shopify-block-{{ block.id }} {
    --highlight-color: {{ highlight_color }};
    {% if highlight_color != "" and highlight_color != "rgba(0,0,0,0)" %}
      --underline-color: {{ underline_color }};
    {% endif %}
  }
</style>
{%- render "settings__block-layout-controls" -%}

<div
  class="section-text {{ text_style }} {{ has_custom_color }} {% if disable_animation %}disable-inview{% endif %} {{ has_underline_class }} {{ custom_font }} leading-normal break-words"
  data-inview
  data-stagger-inview="> *"
  {{ block.shopify_attributes }}
  style="{{ color_style }}">
  {% render 'shortcode-renderer', text: text %}
</div>

{% schema %}
  {
    "name": "Section Text",
    "class": "section-text__wrapper",
    "settings": [
      {
        "type": "richtext",
        "id": "text",
        "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vestibulum vel metus auctor.</p>",
        "label": "Text"
      },
      {
        "type": "checkbox",
        "id": "disable_animation",
        "label": "Disable Animation",
        "default": false
      },
      {
        "type":"select",
        "id":"text_style",
        "options":[
          { "value":"", "label":"Default" },
          { "value":"xsmall", "label":"xSmall" },
          { "value":"small", "label":"Small" },
          { "value":"regular", "label":"Regular" },
          { "value":"large", "label":"Large" },
          { "value":"xlarge", "label":"xLarge" }
        ],
        "label":"Style",
        "default":"regular"
      },
      {
        "type": "select",
        "id": "font_family",
        "label": "Custom Font Family",
        "options": [
          {
            "value": "",
            "label": "Use Theme Settings"
          },
          {
            "value": "custom-font-name-1",
            "label": "Custom Font 1"
          },
          {
            "value": "custom-font-name-2",
            "label": "Custom Font 2"
          },
          {
            "value": "custom-font-name-3",
            "label": "Custom Font 3"
          },
          {
            "value": "custom-font-name-4",
            "label": "Custom Font 4"
          }
        ],
        "default": ""
      },
      {
        "type": "header",
        "content": "Color Settings"
      },
      {
        "type": "color",
        "id": "color",
        "label": "Text Color",
        "info": "Leave it blank to use system settings."
      },
      {
        "type": "color",
        "id": "highlight_color",
        "label": "Highlight Color",
        "info": "This will change the color of all bolded text."
      },
      {
        "type": "color",
        "id": "underline_color",
        "label": "Underline Color",
        "info": "This will add underline (with the set color) to all bolded text."
      },

      {
        "type": "header",
        "content": "Block Layout Controls"
      },
      {
        "type": "paragraph",
        "content": "Width Settings"
      },
      {
        "type": "checkbox",
        "id": "enable_width_settings",
        "label": "Enable Width Settings",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "width_mobile",
        "label": "Width - Mobile",
        "default": false,
        "visible_if": "{{ block.settings.enable_width_settings }}"
      },
      {
        "type": "number",
        "id": "width_mobile_value",
        "label": "Width Value - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit != 'custom' }}"
      },
      {
        "type": "text",
        "id": "width_mobile_custom",
        "label": "Width Custom - Mobile",
        "info": "Use this for custom values or calculations like calc(100% / 3).",
        "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit == 'custom' }}"
      },
      {
        "type": "select",
        "id": "width_mobile_unit",
        "label": "Width Unit - Mobile",
        "options": [
          { "value": "px", "label": "Pixels (px)" },
          { "value": "%", "label": "Percent (%)" },
          { "value": "vw", "label": "Viewport Width (vw)" },
          { "value": "custom", "label": "Custom" }
        ],
        "default": "px",
        "visible_if": "{{ block.settings.width_mobile }}"
      },
      {
        "type": "checkbox",
        "id": "width_desktop",
        "label": "Width - Desktop",
        "default": false,
        "visible_if": "{{ block.settings.enable_width_settings }}"
      },
      {
        "type": "number",
        "id": "width_desktop_value",
