{%- render "settings__block-layout-controls" -%}

{%- assign ar_mobile = block.settings.aspect_ratio_mobile_custom | default: block.settings.aspect_ratio_mobile -%}
{%- assign ar_desktop = block.settings.aspect_ratio_desktop_custom | default: block.settings.aspect_ratio_desktop -%}

{%- if ar_mobile != blank or ar_desktop != blank -%}
  <style>
    {%- if ar_mobile != blank -%}
      @media (max-width: 1023px) {
        #shopify-block-{{ block.id }} .product-card__image-wrap { aspect-ratio: {{ ar_mobile }}; }
      }
    {%- endif -%}
    {%- if ar_desktop != blank -%}
      @media (min-width: 1024px) {
        #shopify-block-{{ block.id }} .product-card__image-wrap { aspect-ratio: {{ ar_desktop }}; }
      }
    {%- endif -%}
  </style>
{%- endif -%}

{%- if block.settings.product != blank -%}
  {%- render "partial__product-card",
    product: block.settings.product,
    override_image: block.settings.image,
    override_description: block.settings.description -%}
{%- else -%}
  <div class="product-card w-full min-h-full flex flex-col border-t border-[var(--carbon,#1e1b22)] large:border bg-[var(--essential-white,#eeece5)] overflow-hidden p-[20px] gap-[22px]">
    <div class="product-card__image-wrap w-full overflow-hidden bg-[rgba(0,0,0,0.05)]"></div>
    <div class="product-card__details flex flex-col gap-[15px]">
      <div class="[font-family:var(--font-heading-h4)] text-[20px] large:text-[26px] font-[500] leading-[1.1] uppercase [color:var(--carbon,#1e1b22)] opacity-30">
        <p>Select a product</p>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product",
  "class": "product-grid__item",
  "settings": [
    {
      "type": "header",
      "content": "Product Settings"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Custom Image",
      "info": "Override the product image. Leave blank to use the product's featured image."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Custom Description",
      "info": "Override the product description. Leave blank to use the product's description."
    },
    {
      "type": "header",
      "content": "Aspect Ratio Settings"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Aspect Ratio - Mobile",
      "options": [
        { "value": "9/16", "label": "9:16 (Portrait)" },
        { "value": "3/4", "label": "3:4" },
        { "value": "2/3", "label": "2:3" },
        { "value": "1/1", "label": "1:1 (Square)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "16/9", "label": "16:9 (Landscape)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "1/1"
    },
    {
      "type": "text",
      "id": "aspect_ratio_mobile_custom",
      "label": "Custom Aspect Ratio - Mobile",
      "info": "Format: width/height e.g. 390/390",
      "visible_if": "{{ block.settings.aspect_ratio_mobile == 'custom' }}"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Aspect Ratio - Desktop",
      "options": [
        { "value": "9/16", "label": "9:16 (Portrait)" },
        { "value": "1/1", "label": "1:1 (Square)" },
        { "value": "4/3", "label": "4:3" },
        { "value": "3/2", "label": "3:2" },
        { "value": "16/9", "label": "16:9 (Landscape)" },
        { "value": "21/9", "label": "21:9 (Ultrawide)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "1/1"
    },
    {
      "type": "text",
      "id": "aspect_ratio_desktop_custom",
      "label": "Custom Aspect Ratio - Desktop",
      "info": "Format: width/height e.g. 500/500",
      "visible_if": "{{ block.settings.aspect_ratio_desktop == 'custom' }}"
    },
    {
      "type": "header",
      "content": "Block Layout Controls"
    },
    {
      "type": "paragraph",
      "content": "Width Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_width_settings",
      "label": "Enable Width Settings",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "width_mobile",
      "label": "Width - Mobile",
      "default": false,
      "visible_if": "{{ block.settings.enable_width_settings }}"
    },
    {
      "type": "number",
      "id": "width_mobile_value",
      "label": "Width Value - Mobile",
      "default": 0,
      "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit != 'custom' }}"
    },
    {
      "type": "text",
      "id": "width_mobile_custom",
      "label": "Width Custom - Mobile",
      "info": "Use this for custom values or calculations like calc(100% / 3).",
      "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile_unit",
      "label": "Width Unit - Mobile",
      "options": [
        { "value": "px", "label": "Pixels (px)" },
        { "value": "%", "label": "Percent (%)" },
        { "value": "vw", "label": "Viewport Width (vw)" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "px",
      "visible_if": "{{ block.settings.width_mobile }}"
    },
    {
      "type": "checkbox",
