{%- capture slides_content -%}
  {%- assign articles = block.settings.blog.articles -%}
  {% if articles != blank %}
    {%- for article in articles limit: block.settings.posts_limit -%}
      <div class="blog-carousel__entry mfr-carousel__item shrink-0 py-0 px-[0.625rem] min-h-full flex items-stretch">
        <div class="blog-carousel__entry-inner w-[19.625rem] flex flex-col items-start">
          {% render 'partial__blog-card',
            featured_article: article,
            settings: section.settings %}
        </div>
      </div>
    {%- endfor -%}
  {%- elsif request.design_mode -%}
    {% for i in (1..5) %}
      <div class="blog-carousel__entry mfr-carousel__item shrink-0 py-0 px-[0.625rem] min-h-full flex items-stretch">
        <div class="blog-carousel__entry-inner w-[19.625rem] flex flex-col items-start">
          {% render 'partial__blog-card',
            featured_article: article,
            settings: section.settings %}
        </div>
      </div>
    {% endfor %}
  {% endif %}
{%- endcapture -%}

{% render 'mfr-component__carousel',
  settings: '{
    contain: true,
    wrapAround: false,
    groupCells: true,
    mobileSettings: {
      cellAlign: "center",
      wrapAround: true
    }
  }',
  class: "blog-carousel__carousel",
  content: slides_content
%}

{% schema %}
  {
    "name": "Blog Carousel",
    "class": "blog-carousel",
    "settings": [
      {
        "type": "blog",
        "id": "blog",
        "label": "Blog"
      },
      {
        "type": "number",
        "id": "posts_limit",
        "label": "Posts Limit",
        "default": 10
      }
    ]
  }
{% endschema %}
