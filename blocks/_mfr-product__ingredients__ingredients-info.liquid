{%- render 'settings__block-layout-controls' -%}

{%- assign ingredients = block.settings.product_ingredients -%}
{%- assign title_key = block.settings.title_key | default: 'title' -%}
{%- assign caption_key = block.settings.caption_key | default: 'caption' -%}

<div class="ingredients-info">
  <div class="ingredients-info__inner flex flex-col gap-[20px] large:gap-[30px] uppercase [color:var(--section-heading)]">

    {%- if block.settings.heading != blank or block.settings.caption != blank -%}
      <div class="ingredients-info__header flex flex-col gap-[20px]">
        {%- if block.settings.heading != blank -%}
          <div class="ingredients-info__heading [font-family:var(--font-heading-h4)] text-[20px] large:text-[26px] font-[500] leading-[1.1]">
            <p>{{ block.settings.heading }}</p>
          </div>
        {%- endif -%}
        {%- if block.settings.caption != blank -%}
          <div class="ingredients-info__caption [font-family:var(--custom-font-name-2)] text-[14px] font-[700] leading-[1.4] large:leading-[1.5]">
            <p>{{ block.settings.caption }}</p>
          </div>
        {%- endif -%}
      </div>
    {% endif %}

    <div class="ingredients-info__items flex flex-col">
      {%- if ingredients != blank -%}
        {%- for entry in ingredients -%}
          {%- assign entry_title = entry[title_key] -%}
          {%- assign entry_caption = entry[caption_key] -%}
          <div class="ingredients-info__item flex flex-col gap-[20px] py-[20px]">
            {%- if entry_title != blank -%}
              <div class="ingredients-info__item-title [font-family:var(--font-heading-h4)] text-[16px] font-[700] leading-[1.5]">
                <p>{{ entry_title }}</p>
              </div>
            {%- endif -%}
            {%- if entry_caption != blank -%}
              <div class="ingredients-info__item-caption [font-family:var(--custom-font-name-2)] text-[12px] large:text-[14px] font-[700] leading-[1.4] large:leading-[20px] opacity-70">
                <p>{{ entry_caption }}</p>
              </div>
            {%- endif -%}
          </div>
          {%- unless forloop.last -%}
            <div class="ingredients-info__item-divider"></div>
          {%- endunless -%}
        {%- endfor -%}
      {%- else -%}
        {%- content_for "blocks" -%}
      {%- endif -%}
    </div>

    <div class="ingredients-info__bottom-rule"></div>

  </div>
</div>

