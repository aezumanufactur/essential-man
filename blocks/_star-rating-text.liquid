{%- render "settings__block-layout-controls" -%}

<div class="star-rating-text__inner inline-flex flex-col items-start justify-center gap-[0.125rem] large:flex-row large:items-end large:justify-start large:gap-[0.875rem]">
  <div class="star-rating-text__stars [&_img]:block [&_img]:w-full">
    {%- capture stars_svg -%}
      {%- assign color = section.settings.color_scheme.settings.icons -%}
      {%- assign count = block.settings.star_rating -%}
      <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="128" height="24">
        <path fill="{{ color | default: 'currentColor' }}" d="M12 18L4.9465771 21.708204L6.2936611 13.854102L0.58732182 8.2917957L8.4732885 7.1458979L12 0L15.526711 7.1458979L23.412678 8.2917957L17.706339 13.854102L19.053423 21.708204L12 18Z" fill-rule="evenodd"/>
        <path
          {% if count >= 2 %}
            fill="{{ color | default: 'currentColor' }}"
          {% else %}
            fill="transparent"
            stroke="{{ color | default: 'currentColor' }}"
          {% endif %}
          transform="translate(26 0)" d="M12 18L4.9465771 21.708204L6.2936611 13.854102L0.58732182 8.2917957L8.4732885 7.1458979L12 0L15.526711 7.1458979L23.412678 8.2917957L17.706339 13.854102L19.053423 21.708204L12 18Z" fill-rule="evenodd"/>
        <path
          {% if count >= 3 %}
            fill="{{ color | default: 'currentColor' }}"
          {% else %}
            fill="transparent"
            stroke="{{ color | default: 'currentColor' }}"
          {% endif %}
          transform="translate(52 0)" d="M12 18L4.9465771 21.708204L6.2936611 13.854102L0.58732182 8.2917957L8.4732885 7.1458979L12 0L15.526711 7.1458979L23.412678 8.2917957L17.706339 13.854102L19.053423 21.708204L12 18Z" fill-rule="evenodd"/>
        <path
          {% if count >= 4 %}
            fill="{{ color | default: 'currentColor' }}"
          {% else %}
            fill="transparent"
            stroke="{{ color | default: 'currentColor' }}"
          {% endif %}
          transform="translate(78 0)" d="M12 18L4.9465771 21.708204L6.2936611 13.854102L0.58732182 8.2917957L8.4732885 7.1458979L12 0L15.526711 7.1458979L23.412678 8.2917957L17.706339 13.854102L19.053423 21.708204L12 18Z" fill-rule="evenodd"/>
        <path
          {% if count >= 5 %}
            fill="{{ color | default: 'currentColor' }}"
          {% else %}
            fill="transparent"
            stroke="{{ color | default: 'currentColor' }}"
          {% endif %}
          transform="translate(104 0)" d="M12 18L4.9465771 21.708204L6.2936611 13.854102L0.58732182 8.2917957L8.4732885 7.1458979L12 0L15.526711 7.1458979L23.412678 8.2917957L17.706339 13.854102L19.053423 21.708204L12 18Z" fill-rule="evenodd"/>
      </svg>
    {%- endcapture -%}
    {% render 'component__svg-encoder',
      svg_code: stars_svg,
      width: 128,
      alt: "stars" %}
  </div>
  <p class="star-rating-text__text leading-[1.4em] block">
    {{ block.settings.text }}
  </p>
</div>

{% schema %}
  {
    "name": "Star Rating Text",
    "class": "star-rating-text",
    "settings": [
      {
        "type": "range",
        "id": "star_rating",
        "min": 1,
        "max": 5,
        "step": 1,
        "unit": "☆",
        "label": "Stars",
        "default": 5
      },
      {
        "type": "text",
        "id": "text",
        "label": "Text",
        "default": "Over 2,000+ verified 5-star reviews"
      },
      {
        "type": "header",
        "content": "Block Layout Controls"
      },
      {
        "type": "paragraph",
        "content": "Width Settings"
      },
      {
        "type": "checkbox",
        "id": "enable_width_settings",
        "label": "Enable Width Settings",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "width_mobile",
        "label": "Width - Mobile",
        "default": false,
        "visible_if": "{{ block.settings.enable_width_settings }}"
      },
      {
        "type": "number",
        "id": "width_mobile_value",
        "label": "Width Value - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit != 'custom' }}"
      },
      {
        "type": "text",
        "id": "width_mobile_custom",
        "label": "Width Custom - Mobile",
        "info": "Use this for custom values or calculations like calc(100% / 3).",
        "visible_if": "{{ block.settings.width_mobile and block.settings.width_mobile_unit == 'custom' }}"
      },
      {
        "type": "select",
        "id": "width_mobile_unit",
        "label": "Width Unit - Mobile",
        "options": [
          { "value": "px", "label": "Pixels (px)" },
          { "value": "%", "label": "Percent (%)" },
          { "value": "vw", "label": "Viewport Width (vw)" },
          { "value": "custom", "label": "Custom" }
        ],
        "default": "px",
        "visible_if": "{{ block.settings.width_mobile }}"
      },
      {
        "type": "checkbox",
        "id": "width_desktop",
        "label": "Width - Desktop",
        "default": false,
        "visible_if": "{{ block.settings.enable_width_settings }}"
      },
      {
        "type": "number",
        "id": "width_desktop_value",
        "label": "Width Value - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.width_desktop and block.settings.width_desktop_unit != 'custom' }}"
      },
      {
        "type": "text",
        "id": "width_desktop_custom",
        "label": "Width Custom - Desktop",
        "info": "Use this for custom values or calculations like calc(100% / 3).",
        "visible_if": "{{ block.settings.width_desktop and block.settings.width_desktop_unit == 'custom' }}"
      },
      {
        "type": "select",
        "id": "width_desktop_unit",
        "label": "Width Unit - Desktop",
        "options": [
          { "value": "px", "label": "Pixels (px)" },
          { "value": "%", "label": "Percent (%)" },
          { "value": "vw", "label": "Viewport Width (vw)" },
          { "value": "custom", "label": "Custom" }
        ],
        "default": "px",
        "visible_if": "{{ block.settings.width_desktop }}"
      },
      {
        "type": "paragraph",
        "content": "Padding Settings"
      },
      {
        "type": "checkbox",
        "id": "enable_padding_settings",
        "label": "Enable Padding Settings",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "padding_x_mobile",
        "label": "Padding X - Mobile",
        "default": false,
        "visible_if": "{{ block.settings.enable_padding_settings }}"
      },
      {
        "type": "number",
        "id": "padding_left_mobile",
        "label": "Padding Left - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.padding_x_mobile }}"
      },
      {
        "type": "number",
        "id": "padding_right_mobile",
        "label": "Padding Right - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.padding_x_mobile }}"
      },
      {
        "type": "checkbox",
        "id": "padding_y_mobile",
        "label": "Padding Y - Mobile",
        "default": false,
        "visible_if": "{{ block.settings.enable_padding_settings }}"
      },
      {
        "type": "number",
        "id": "padding_top_mobile",
        "label": "Padding Top - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.padding_y_mobile }}"
      },
      {
        "type": "number",
        "id": "padding_bottom_mobile",
        "label": "Padding Bottom - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.padding_y_mobile }}"
      },
      {
        "type": "checkbox",
        "id": "padding_x_desktop",
        "label": "Padding X - Desktop",
        "default": false,
        "visible_if": "{{ block.settings.enable_padding_settings }}"
      },
      {
        "type": "number",
        "id": "padding_left_desktop",
        "label": "Padding Left - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.padding_x_desktop }}"
      },
      {
        "type": "number",
        "id": "padding_right_desktop",
        "label": "Padding Right - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.padding_x_desktop }}"
      },
      {
        "type": "checkbox",
        "id": "padding_y_desktop",
        "label": "Padding Y - Desktop",
        "default": false,
        "visible_if": "{{ block.settings.enable_padding_settings }}"
      },
      {
        "type": "number",
        "id": "padding_top_desktop",
        "label": "Padding Top - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.padding_y_desktop }}"
      },
      {
        "type": "number",
        "id": "padding_bottom_desktop",
        "label": "Padding Bottom - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.padding_y_desktop }}"
      },
      {
        "type": "paragraph",
        "content": "Margin Settings"
      },
      {
        "type": "checkbox",
        "id": "enable_margin_settings",
        "label": "Enable Margin Settings",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "margin_x_mobile",
        "label": "Margin X - Mobile",
        "default": false,
        "visible_if": "{{ block.settings.enable_margin_settings }}"
      },
      {
        "type": "number",
        "id": "margin_left_mobile",
        "label": "Margin Left - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.margin_x_mobile }}"
      },
      {
        "type": "number",
        "id": "margin_right_mobile",
        "label": "Margin Right - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.margin_x_mobile }}"
      },
      {
        "type": "checkbox",
        "id": "margin_y_mobile",
        "label": "Margin Y - Mobile",
        "default": false,
        "visible_if": "{{ block.settings.enable_margin_settings }}"
      },
      {
        "type": "number",
        "id": "margin_top_mobile",
        "label": "Margin Top - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.margin_y_mobile }}"
      },
      {
        "type": "number",
        "id": "margin_bottom_mobile",
        "label": "Margin Bottom - Mobile",
        "default": 0,
        "visible_if": "{{ block.settings.margin_y_mobile }}"
      },
      {
        "type": "checkbox",
        "id": "margin_x_desktop",
        "label": "Margin X - Desktop",
        "default": false,
        "visible_if": "{{ block.settings.enable_margin_settings }}"
      },
      {
        "type": "number",
        "id": "margin_left_desktop",
        "label": "Margin Left - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.margin_x_desktop }}"
      },
      {
        "type": "number",
        "id": "margin_right_desktop",
        "label": "Margin Right - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.margin_x_desktop }}"
      },
      {
        "type": "checkbox",
        "id": "margin_y_desktop",
        "label": "Margin Y - Desktop",
        "default": false,
        "visible_if": "{{ block.settings.enable_margin_settings }}"
      },
      {
        "type": "number",
        "id": "margin_top_desktop",
        "label": "Margin Top - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.margin_y_desktop }}"
      },
      {
        "type": "number",
        "id": "margin_bottom_desktop",
        "label": "Margin Bottom - Desktop",
        "default": 0,
        "visible_if": "{{ block.settings.margin_y_desktop }}"
      }
    ],
    "presets": [
      {
        "name": "Star Rating Text"
      }
    ]
  }
{% endschema %}
