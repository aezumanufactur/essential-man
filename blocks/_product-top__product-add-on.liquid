{%- render "settings__block-layout-controls" -%}

{%- assign addon_product = all_products[block.settings.product] -%}

{%- if addon_product != blank and addon_product.id != product.id -%}

  {%- assign addon_variant = addon_product.selected_or_first_available_variant -%}
  {%- assign addon_image = block.settings.image | default: addon_product.featured_image -%}
  {%- assign addon_form_id = 'product-add-on-form-' | append: block.id -%}
  {%- if addon_variant.available -%}
    {%- assign open_off_canvas = 'x-on:click="$store[`offCanvasCart`].openOffcanvas(); $store[`offCanvasProductForm`].closeOffcanvas()"' -%}
  {%- else -%}
    {%- assign open_off_canvas = '' -%}
  {%- endif -%}

  <style>
    #shopify-block-{{ block.id }} .product-add-on__card {
      background-color: {{ block.settings.card_bg_color }};
    }
    #shopify-block-{{ block.id }} .product-add-on__image-bg {
      background-color: {{ block.settings.image_bg_color }};
    }
    #shopify-block-{{ block.id }} .product-add-on__title {
      color: {{ block.settings.title_color }};
    }
    #shopify-block-{{ block.id }} .product-add-on__description {
      color: {{ block.settings.description_color }};
    }
  </style>

  <div class="product-add-on flex flex-col gap-[20px] w-full">

    {%- if block.settings.heading != blank or block.settings.caption != blank -%}
      <div class="product-add-on__header flex flex-col gap-[8px]">
        {%- if block.settings.heading != blank -%}
          <div class="product-add-on__heading [font-family:var(--font-heading-h4)] text-[16px] font-[700] leading-[1.4] large:leading-[1.5] uppercase">
            <p>{{ block.settings.heading }}</p>
          </div>
        {%- endif -%}
        {%- if block.settings.caption != blank -%}
          <div class="product-add-on__caption [font-family:var(--font-body)] text-[12px] large:text-[14px] font-[700] leading-[1.4] large:leading-[20px] uppercase opacity-60">
            <p>{{ block.settings.caption }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="product-add-on__card flex flex-row overflow-hidden rounded-[10px] border border-[currentColor] w-full">

      <div class="product-add-on__image-section relative w-[145px] shrink-0 self-stretch overflow-hidden">
        <div class="product-add-on__image-bg absolute inset-0 opacity-[0.56]"></div>
        {%- if addon_image != blank -%}
          <img
            src="{{ addon_image | image_url: width: 290 }}"
            alt="{{ addon_image.alt | escape }}"
            width="{{ addon_image.width }}"
            height="{{ addon_image.height }}"
            loading="lazy"
            class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[70%] h-[90%] object-contain">
        {%- endif -%}
      </div>

      <div class="product-add-on__divider w-px shrink-0 bg-[currentColor]"></div>

      <div class="product-add-on__content flex flex-col gap-[12px] large:gap-[15px] py-[15px] pl-[20px] pr-[14px] flex-1 min-w-0">

        {%- if block.settings.pilled_text != blank -%}
          <div class="product-add-on__pill inline-flex items-center self-start rounded-[5px] overflow-hidden px-[8px] py-[7px] bg-[#647949]">
            <div class="product-add-on__pill-text [font-family:var(--font-body)] text-[12px] font-[700] leading-[20px] uppercase text-[#eeece5] whitespace-nowrap">
              <p>{{ block.settings.pilled_text }}</p>
            </div>
          </div>
        {%- endif -%}

        {%- if block.settings.title != blank -%}
          <div class="product-add-on__title [font-family:var(--font-heading-h4)] text-[20px] large:text-[26px] font-[500] leading-[1.1] uppercase w-full">
            <p>{{ block.settings.title }}</p>
          </div>
        {%- endif -%}

        {%- if block.settings.description != blank -%}
          <div class="product-add-on__description [font-family:var(--font-body)] text-[12px] large:text-[14px] font-[700] leading-[1.4] large:leading-[20px] uppercase opacity-60 w-full">
            <p>{{ block.settings.description }}</p>
          </div>
        {%- endif -%}

        {%- form 'product',
          addon_product,
          id: addon_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form',
          x-data: 'MFRProductForm()' -%}
          {%- render 'product-form__hidden-input', product: addon_product -%}
          <button
            type="submit"
            class="product-add-on__button bg-[#eeece5] border border-[currentColor] rounded-[5px] h-[42px] px-[20px] overflow-hidden flex items-center justify-center w-full"
            {%- if addon_variant.available == false or addon_variant == null -%}disabled{%- endif -%}
            {{ open_off_canvas }}>
            <div class="product-add-on__button-text [font-family:var(--font-heading-h4)] text-[15px] font-[500] leading-[1] uppercase text-center whitespace-nowrap">
              <p>
                {{- block.settings.atc_label }} — {{ addon_variant.price | money_without_trailing_zeros -}}
                {%- if addon_variant.compare_at_price > addon_variant.price -%}
                  <span class="line-through opacity-50"> {{ addon_variant.compare_at_price | money_without_trailing_zeros }}</span>
                {%- endif -%}
              </p>
            </div>
          </button>
        {%- endform -%}

        {%- render 'script__section', file: "MFRProductForm.js" -%}

      </div>
    </div>
  </div>

{%- else -%}
  <style>#shopify-block-{{ block.id }} { display: none; }</style>
{%- endif -%}

