{%- render "settings__block-layout-controls" -%}

{%- assign pill_color = block.settings.color -%}
{%- assign pill_bg = block.settings.color_background -%}

{%- capture pill_style -%}
  {%- if pill_color != blank and pill_color != 'rgba(0,0,0,0)' -%}color: {{ pill_color }};{%- endif -%}
  {%- if pill_bg != blank and pill_bg != 'rgba(0,0,0,0)' -%}background-color: {{ pill_bg }};{%- endif -%}
{%- endcapture -%}

<div class="product-top__pilled-text">
  <div class="product-top__pilled-text__inner inline-block">
    <div
      class="product-top__pilled-text__pill [font-family:var(--font-body)] text-[12px] font-[700] leading-[20px] uppercase rounded-[5px] px-[8px] py-[7px]"
      style="{{ pill_style }}">
      <span>{{ block.settings.text }}</span>
    </div>
  </div>
</div>

