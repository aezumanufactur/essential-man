<style>
  #shopify-block-{{ block.id }} {
    {%- if block.settings.text_color != blank -%}
      --text-color: {{ block.settings.text_color }};
    {%- endif -%}
    {%- if block.settings.bg_color != blank -%}
      --bg-color: {{ block.settings.bg_color }};
    {%- endif -%}
    text-align: {{ block.settings.text_align_mobile }};
  }
  #shopify-block-{{ block.id }} p {
    {%- if block.settings.font_family != blank -%}
      font-family: var(--{{ block.settings.font_family }});
    {%- endif -%}
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: uppercase;
    {%- if block.settings.enable_font_settings -%}
      {%- if block.settings.font_size_mobile > 0 -%}font-size: {{ block.settings.font_size_mobile }}px;{%- endif -%}
      {%- if block.settings.line_height_mobile > 0 -%}line-height: {{ block.settings.line_height_mobile }}px;{%- endif -%}
      {%- if block.settings.letter_spacing_mobile != 0 -%}letter-spacing: {{ block.settings.letter_spacing_mobile }}px;{%- endif -%}
      {%- if block.settings.font_weight_mobile != blank -%}font-weight: {{ block.settings.font_weight_mobile }};{%- endif -%}
      {%- if block.settings.font_case != blank -%}text-transform: {{ block.settings.font_case }};{%- endif -%}
    {%- endif -%}
  }
  @media (min-width: 1024px) {
    #shopify-block-{{ block.id }} {
      text-align: {{ block.settings.text_align_desktop }};
    }
    #shopify-block-{{ block.id }} p {
      line-height: 1.5;
      {%- if block.settings.enable_font_settings -%}
        {%- if block.settings.font_size_desktop > 0 -%}font-size: {{ block.settings.font_size_desktop }}px;{%- endif -%}
        {%- if block.settings.line_height_desktop > 0 -%}line-height: {{ block.settings.line_height_desktop }}px;{%- endif -%}
        {%- if block.settings.letter_spacing_desktop != 0 -%}letter-spacing: {{ block.settings.letter_spacing_desktop }}px;{%- endif -%}
        {%- if block.settings.font_weight_desktop != blank -%}font-weight: {{ block.settings.font_weight_desktop }};{%- endif -%}
      {%- endif -%}
    }
  }
  {%- if block.settings.image_max_width_mobile > 0 -%}
  #shopify-block-{{ block.id }} img {
    max-width: {{ block.settings.image_max_width_mobile }}px;
  }
  {%- endif -%}
  @media (min-width: 1024px) {
    {%- if block.settings.image_max_width_desktop > 0 -%}
    #shopify-block-{{ block.id }} img {
      max-width: {{ block.settings.image_max_width_desktop }}px;
    }
    {%- endif -%}
  }
</style>
{%- render "settings__block-layout-controls" -%}
{%- if block.settings.image != blank -%}
  {%- assign default_alt = "maybe an image about " | append: block.settings.text -%}
  {%- assign alt = block.settings.image.alt | default: default_alt -%}
  {%- render 'component__lazyload-image',
    image: block.settings.image,
    width: 240,
    alt: alt -%}
{%- elsif block.settings.text != blank -%}
  <p>{{ block.settings.text }}</p>
{%- endif -%}
