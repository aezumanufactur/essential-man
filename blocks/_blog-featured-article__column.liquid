{%- render 'settings__block-layout-controls' -%}
<style>
  #shopify-block-{{ block.id }} {
    justify-content: {{ block.settings.vertical_alignment | default: 'flex-start' }};
  }
  {%- if block.settings.horizontal_alignment_mobile != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} {
        align-items: {%- if block.settings.horizontal_alignment_mobile == 'left' %} flex-start{%- elsif block.settings.horizontal_alignment_mobile == 'center' %} center{%- else %} flex-end{%- endif %};
        text-align: {{ block.settings.horizontal_alignment_mobile }};
      }
    }
  {%- endif -%}
  {%- if block.settings.horizontal_alignment_desktop != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} {
        align-items: {%- if block.settings.horizontal_alignment_desktop == 'left' %} flex-start{%- elsif block.settings.horizontal_alignment_desktop == 'center' %} center{%- else %} flex-end{%- endif %};
        text-align: {{ block.settings.horizontal_alignment_desktop }};
      }
    }
  {%- endif -%}
  {%- if block.settings.inner_max_width_mobile != 0 and block.settings.inner_max_width_mobile != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} .blog-featured-article__column__inner {
        max-width: {{ block.settings.inner_max_width_mobile }}px;
      }
    }
  {%- endif -%}
  {%- if block.settings.inner_max_width_desktop != 0 and block.settings.inner_max_width_desktop != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} .blog-featured-article__column__inner {
        max-width: {{ block.settings.inner_max_width_desktop }}px;
      }
    }
  {%- endif -%}
  {%- if block.settings.order_mobile != 0 and block.settings.order_mobile != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} { order: {{ block.settings.order_mobile }}; }
    }
  {%- endif -%}
  {%- if block.settings.order_desktop != 0 and block.settings.order_desktop != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} { order: {{ block.settings.order_desktop }}; }
    }
  {%- endif -%}
</style>
<div class="blog-featured-article__column__inner">
  {%- content_for "blocks" -%}
</div>

