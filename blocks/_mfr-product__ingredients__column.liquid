{%- render 'settings__block-layout-controls' -%}

{%- assign sticky_top = block.settings.sticky_top_desktop | default: 0 -%}

<style>
  {%- if block.settings.inner_max_width_mobile != 0 and block.settings.inner_max_width_mobile != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} .ingredients__column__inner {
        max-width: {{ block.settings.inner_max_width_mobile }}px;
      }
    }
  {%- endif -%}
  {%- if block.settings.inner_max_width_desktop != 0 and block.settings.inner_max_width_desktop != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} .ingredients__column__inner {
        max-width: {{ block.settings.inner_max_width_desktop }}px;
      }
    }
  {%- endif -%}
  {%- if block.settings.order_mobile != 0 and block.settings.order_mobile != blank -%}
    @media (max-width: 1023px) {
      #shopify-block-{{ block.id }} { order: {{ block.settings.order_mobile }}; }
    }
  {%- endif -%}
  {%- if block.settings.order_desktop != 0 and block.settings.order_desktop != blank -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} { order: {{ block.settings.order_desktop }}; }
    }
  {%- endif -%}
  {%- if block.settings.enable_sticky_desktop -%}
    @media (min-width: 1024px) {
      #shopify-block-{{ block.id }} {
        height: 100%;
      }
      #shopify-block-{{ block.id }} .ingredients__column {
        position: sticky;
        top: var(--top-offset);
      }
    }
  {%- endif -%}
</style>

<div class="ingredients__column" style="--top-offset: {{ sticky_top }}px;">
  <div class="ingredients__column__inner flex flex-col [align-items:var(--ingredients-col-h-align-mobile)] [justify-content:var(--ingredients-col-v-align-mobile)] large:[align-items:var(--ingredients-col-h-align-desktop)] large:[justify-content:var(--ingredients-col-v-align-desktop)]"
    style="
      --ingredients-col-h-align-mobile: {{ block.settings.horizontal_alignment_mobile | default: 'flex-start' }};
      --ingredients-col-v-align-mobile: {{ block.settings.vertical_alignment_mobile | default: 'flex-start' }};
      --ingredients-col-h-align-desktop: {{ block.settings.horizontal_alignment_desktop | default: 'flex-start' }};
      --ingredients-col-v-align-desktop: {{ block.settings.vertical_alignment_desktop | default: 'flex-start' }};
    ">
    {%- content_for "blocks" -%}
  </div>
</div>

