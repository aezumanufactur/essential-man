{%- if block.blocks.size > 0 -%}
  {% assign max_width_mobile = block.settings.max_width_mobile %}
  {% assign max_width_desktop = block.settings.max_width_desktop %}
  {% assign rows_mobile = block.settings.rows_mobile %}
  {% assign rows_tablet = block.settings.rows_tablet %}
  {% assign rows_desktop = block.settings.rows_desktop %}

  <style>
    #shopify-block-{{ block.id }} {
      {% if max_width_mobile != blank and max_width_mobile != 0 %}
        --max-width-mobile: {{ max_width_mobile }}px;
      {% endif %}
      {% if max_width_desktop != blank and max_width_desktop != 0 %}
        --max-width-desktop: {{ max_width_desktop }}px;
      {% endif %}
      --gap-mobile: {{ block.settings.gap_mobile | default: 7 }}px;
      --gap-desktop: {{ block.settings.gap_desktop | default: 15 }}px;
      --wrapper-gap-mobile: {{ block.settings.gap_mobile | default: 7 }}px;
      --wrapper-gap-desktop: {{ block.settings.gap_desktop | default: 15 }}px;
      {% if block.settings.use_dynamic_sizing_mobile and rows_mobile > 0 %}
        --items-dynamic-width-mobile: calc((100% - (var(--gap-mobile) * {{ rows_mobile | minus: 1 }})) / {{ rows_mobile }});
      {% endif %}
      {% if block.settings.use_dynamic_sizing_tablet and rows_tablet > 0 %}
        --items-dynamic-width-tablet: calc((100% - (var(--gap-mobile) * {{ rows_tablet | minus: 1 }})) / {{ rows_tablet }});
      {% endif %}
      {% if block.settings.use_dynamic_sizing_desktop and rows_desktop > 0 %}
        --items-dynamic-width-desktop: calc((100% - (var(--gap-desktop) * {{ rows_desktop | minus: 1 }})) / {{ rows_desktop }});
      {% endif %}
    }
  </style>

  <div class="section-icon-text__inner flex [justify-content:inherit] items-start flex-wrap w-full max-w-[var(--max-width-mobile)] gap-[var(--gap-mobile)] large:max-w-[var(--max-width-desktop)] large:gap-[var(--gap-desktop)]{% if block.settings.use_dynamic_sizing_mobile %} dynamic--mobile{% endif %}{% if block.settings.use_dynamic_sizing_tablet %} dynamic--tablet{% endif %}{% if block.settings.use_dynamic_sizing_desktop %} dynamic--desktop{% endif %}"
    data-stagger-inview=".section-icon-text__item">
    {%- content_for "blocks" -%}
  </div>
{%- endif -%}

{%- schema -%}
  {
    "name": "Icon Text Wrapper",
    "class": "section-icon-text__wrapper",
    "settings": [
      {
        "type": "header",
        "content": "Gap Settings"
      },
      {
        "type": "number",
        "id": "gap_mobile",
        "label": "Gap - Mobile",
        "default": 7,
        "info": "in pixels"
      },
      {
        "type": "number",
        "id": "gap_desktop",
        "label": "Gap - Desktop",
        "default": 15,
        "info": "in pixels"
      },
      {
        "type": "header",
        "content": "Width Settings"
      },
      {
        "type": "number",
        "id": "max_width_mobile",
        "label": "Max Width - Mobile",
        "default": 0,
        "info": "in pixels"
      },
      {
        "type": "number",
        "id": "max_width_desktop",
        "label": "Max Width - Desktop",
        "default": 0,
        "info": "in pixels"
      },
      {
        "type": "header",
        "content": "Dynamic Sizing"
      },
      {
        "type": "checkbox",
        "id": "use_dynamic_sizing_mobile",
        "label": "Use Dynamic Sizing - Mobile",
        "default": false
      },
      {
        "type": "number",
        "id": "rows_mobile",
        "label": "Rows - Mobile",
        "default": 2
      },
      {
        "type": "checkbox",
        "id": "use_dynamic_sizing_tablet",
        "label": "Use Dynamic Sizing - Tablet",
        "default": false
      },
      {
        "type": "number",
        "id": "rows_tablet",
        "label": "Rows - Tablet",
        "default": 3
      },
      {
        "type": "checkbox",
        "id": "use_dynamic_sizing_desktop",
        "label": "Use Dynamic Sizing - Desktop",
        "default": false
      },
      {
        "type": "number",
        "id": "rows_desktop",
        "label": "Rows - Desktop",
        "default": 4
      },
    ],
    "blocks": [
      { "type": "_section-content__icon-text-item" }
    ],
    "presets": [
      {
        "name": "Section Icon Text Wrapper",
        "blocks": [
          { "type": "_section-content__icon-text-item" }
        ]
      }
    ]
  }
{%- endschema -%}