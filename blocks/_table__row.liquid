{%- if block.settings.use_flex -%}
  <style>
    #shopify-block-{{ block.id }} {
      display: flex;
      justify-content: {{ block.settings.flex_justify }};
    }
  </style>
{%- endif -%}
{%- if block.blocks.size > 0 -%}
  {%- content_for "blocks" -%}
{%- endif -%}
{% schema %}
  {
    "name": "Row",
    "class": "table-section__row",
    "tag": "tr",
    "settings": [
      {
        "type": "checkbox",
        "id": "use_flex",
        "label": "Use flex",
        "default": false
      },
      {
        "type": "select",
        "id": "flex_justify",
        "label": "Justify content",
        "options": [
          { "value": "flex-start", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "flex-end", "label": "Right" }
        ],
        "default": "flex-start",
        "visible_if": "{{ block.settings.use_flex == true }}"
      }
    ],
    "blocks": [
      { "type": "_table__item" }
    ],
    "presets": [
      {
        "name": "Row"
      }
    ]
  }
{% endschema %}
