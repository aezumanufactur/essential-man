{% comment %} {% assign disable_animation = true %} {% endcomment %}
{% comment %}
    Attributes

    - block_id
    - text
    - header_style
    - bold_color
    - underline_color
    - max_width
{% endcomment %}

{% assign block_id = block.id %}
{% assign text = block.settings.heading %}
{% assign header_style = block.settings.header_style %}
{% assign highlight_color = block.settings.highlight_color %}
{% assign underline_color = block.settings.underline_color %}
{% assign disable_animation = block.settings.disable_animation %}
{% assign custom_font = block.settings.font_family %}
{% if underline_color != "" and underline_color != "rgba(0,0,0,0)" %}
  {% assign has_underline_class = "has-underline" %}
{% else %}
  {% assign has_underline_class = "" %}
{% endif %}

<style>
  #shopify-block-{{ block.id }} {
    --highlight-color: {{ highlight_color }};
    {% if highlight_color != "" and highlight_color != "rgba(0,0,0,0)" %}
      --underline-color: {{ underline_color }};
    {% endif %}
  }
</style>
{%- render "settings__block-layout-controls" -%}

<{{ block.settings.header_tag }}
  id="block--{{ block_id }}"
  class="section-title {% unless request.visual_preview_mode %}{{ header_style }}{% else %}h2{% endunless %} {{ has_underline_class }} {{ custom_font }} relative inline-block mt-0 w-full"
  data-inview>
  <div class="section-title__inner" 
    {% unless disable_animation %}
      data-split-text="fadeUp"
    {% endunless %}>
    {% render 'shortcode-renderer',
      text: text %}
  </div>
</{{ block.settings.header_tag }}>

{% schema %}
  {
    "name": "Section Title",
    "class": "section-title__wrapper",
    "settings": [
      {
        "type": "inline_richtext",
        "id": "heading",
        "default": "Heading Text",
        "label": "Heading Text"
