{% render 'style-tags__section', asset_file_name: "offcanvas-contact.css" %}

{% capture success_message %}
  {%- assign success_message = section.settings.success_message -%}

  {% if success_message != blank %}
    <div class="offcanvas-contact__success-message">
      {{ success_message }}
    </div>
  {% endif %}
{% endcapture %}

{%- capture contact_form -%}
  {% comment %} Error messages {% endcomment %}
  {%- if form.errors -%}
    {%- for field in form.errors -%}
      <span class="errors">
        {%- if field == 'form' -%}
          {{ form.errors.messages[field] }}
        {%- else -%}
          <strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}
        {%- endif -%}
      </span>
    {%- endfor -%}
  {%- endif -%}

  {%- for block in section.blocks -%}
    <div class="form-{{ block.type }}">
      {%- case block.type -%}
        {% comment %} Email and name fields {% endcomment %}
        {%- when 'email' -%}
          {%- if block.settings.separate_name -%}
            <div class="form-inner two-column flex flex-col items-stretch">
              <div class="form-inner flex flex-col items-stretch">
                <label for="contactFormFirstName">First Name</label>
                <input type="text" id="contactFormFirstName" name="contact[first_name]" tabindex="0" placeholder="Enter your first name" autocapitalize="words" required value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
              </div>
              <div class="form-inner flex flex-col items-stretch">
                <label for="contactFormLastName">Last Name</label>
                <input type="text" id="contactFormLastName" name="contact[last_name]" tabindex="0" placeholder="Enter your last name" autocapitalize="words" required value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
              </div>
            </div>
          {%- else -%}
            <div class="form-inner flex flex-col items-stretch">
              <label for="contactFormName">Name</label>
              <input type="text" id="contactFormName" name="contact[name]" tabindex="0" placeholder="{{ block.settings.name_placeholder }}" autocapitalize="words" required value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
            </div>
          {%- endif -%}

          <div class="form-inner flex flex-col items-stretch">
            <label for="contactFormEmail">Email</label>
            <input type="email" id="contactFormEmail" name="contact[email]" placeholder="{{ block.settings.email_placeholder }}" autocorrect="off" autocapitalize="off" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
          </div>

        {% comment %} Form fields {% endcomment %}
        {%- when 'field' -%}
          {%- assign id = block.id | prepend: 'field' -%}

          <label for="{{ id }}" class="block [font-size:var(--font-body-size-small)] leading-[1em] font-medium mb-[10px]">{{ block.settings.label | escape }}</label>
          {% if block.settings.type == 'input' %}
            <input type="text"
          {% else %}
            <textarea
          {% endif %}
              id="{{ id }}" name="contact[{{ block.settings.label | handleize }}]"
              placeholder="{{ block.settings.placeholder | escape }}"
              autocorrect="off" autocapitalize="off" autocomplete="off"
              {% if block.settings.required %} required {% endif %}>
          {%- if block.settings.type == 'textarea' -%}
            </textarea>
          {%- endif -%}

        {% comment %} Dropdown fields {% endcomment %}
        {%- when 'dropdown' -%}
          {%- assign id = block.id | prepend: 'dropdown' -%}
          {%- assign options = block.settings.options | newline_to_br | strip_newlines | split: '<br />' -%}

          <label for="{{ id }}" class="block [font-size:var(--font-body-size-small)] leading-[1em] font-medium mb-[10px]">{{ block.settings.label | escape }}</label>
          <div class="form__select relative">
            <select id="{{ id }}" name="contact[{{ block.settings.label | handleize }}]" {% if block.settings.required %}required{% endif %}>
              <option value="" disabled selected>{{ block.settings.placeholder | default: block.settings.label | escape }}</option>
              {%- for option in options -%}
                <option value="{{- option -}}">{{- option -}}</option>
              {%- endfor -%}
            </select>
            {%- render 'icon__carets', position: 'down' -%}
          </div>

        {% comment %} Submit field {% endcomment %}
        {%- when 'button' -%}
          <button type="submit" role="button" class="button {{ block.settings.color_theme }} w-full" aria-label="{{ block.settings.label | escape }}">
            <span class="text">{{ block.settings.label | escape }}</span>
          </button>
      {%- endcase -%}
    </div>
  {%- endfor -%}
{%- endcapture -%}

{%- capture contact_content -%}
  {% render 'renderer__color-scheme', name: "section", color_scheme: section.settings.color_scheme, selector: ".shopify-section", section_id: "offCanvasContact" %}

  <div class="offcanvas-contact__content relative flex h-full w-full flex-col pr-[38px]"
    x-data
    :style='{ paddingTop: $store.offCanvas.announcementBarHeight + "px" }'>

    <button class="absolute right-[8px] w-[42px] h-[42px] z-10"
      :style='{ top: ($store.offCanvas.announcementBarHeight + 14) + "px" }'
      x-data
      @click='$store["offCanvasContact"].closeOffcanvas()'
      aria-label="Close contact">
      {%- render 'icon__close-with-circle' -%}
    </button>

    <div class="offcanvas-contact__inner flex flex-1 flex-col overflow-auto px-[21px] pt-[40px] pb-[40px] gap-[25px] [background:var(--section-background)] [color:var(--section-text)]">
      <div class="offcanvas-contact__header flex flex-col gap-[25px] uppercase [color:var(--section-text)]">
        {%- if section.settings.title != blank -%}
          <div class="text-[34px] font-medium leading-[1.1] [font-family:var(--font-heading-h2)]">
            {{ section.settings.title }}
          </div>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="text-[14px] leading-[1.4] [font-family:var(--font-body)]">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.embed_code != blank -%}
        <div class="offcanvas-contact__form--embed mt-auto">
          {{ section.settings.embed_code }}
        </div>
      {%- else -%}
        <div class="offcanvas-contact__form flex flex-col items-stretch w-full mt-auto">
          {%- assign form_id = section.id | prepend: 'form-' -%}

          {% form 'contact', id: form_id, class: 'simple-form mfr-contact' %}
            {% comment %} Notification {% endcomment %}
            {% if form.posted_successfully? %}
              {% render "component__notification",
                show: true,
                type: "success",
                title: "Success!",
                description: "Form submission success!",
                id: "form-notification"
              %}
            {% elsif form.errors != blank %}
              {% render "component__notification",
                show: true,
                type: "error",
                title: "Error",
                description: "There are some error(s) after Contact form submission",
                errors: form.errors
                id: "form-notification"
              %}
            {% endif %}

            {% comment %} Success message {% endcomment %}
            {% if form.posted_successfully? %}
              {{ success_message }}
            {% else %}
              {{ contact_form }}
            {% endif %}
          {% endform %}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endcapture -%}

{%- capture x_init -%}
  const urlParams = new URLSearchParams(window.location.search);

  if (urlParams.get("contact_posted") === "true") {
    $store.offCanvas.contact = true
  }
{%- endcapture -%}

{% render 'mfr-component__offcanvas',
  id: "offCanvasContact",
  class: "offcanvas-contact",
  position: "left",
  content: contact_content,
  x_init: x_init
%}

{% schema %}
{
  "name": "Slideout Contact",
  "enabled_on": {
    "groups": ["custom.offcanvas"]
  },
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Contact"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We respond within one business day. For press or wholesale, include the relevant context in your message.</p>"
    },
    {
      "type": "textarea",
      "id": "embed_code",
      "label": "Form Code",
      "info": "Embed code will hide input blocks"
    },
    {
      "type": "richtext",
      "id": "success_message",
      "label": "Success Message"
    },
    {
      "type": "header",
      "content": "Color Schemes"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color Options",
      "info": "This will be the color scheme of the header initially."
    }
  ],
  "blocks": [
    {
      "type": "email",
      "name": "Name & Email",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "separate_name",
          "label": "Split first and last names",
          "default": false
        },
        {
          "type": "text",
          "id": "name_placeholder",
          "label": "Name Placeholder",
          "default": "John Doe"
        },
        {
          "type": "text",
          "id": "email_placeholder",
          "label": "Email Placeholder",
          "default": "name@company.com"
        }
      ]
    },
    {
      "type": "field",
      "name": "Form field",
      "settings": [
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required"
        },
        {
          "type": "select",
          "id": "type",
          "label": "Type",
          "options": [
            { "value": "input", "label": "Single line" },
            { "value": "textarea", "label": "Multi line" }
          ],
          "default": "input"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Placeholder"
        }
      ]
    },
    {
      "type": "dropdown",
      "name": "Dropdown",
      "settings": [
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "textarea",
          "id": "options",
          "label": "Options",
          "info": "Separated by new line"
        }
      ]
    },
    {
      "type": "button",
      "name": "Submit",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Submit"
        },
        {
          "type": "select",
          "id": "color_theme",
          "label": "Color Theme",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" },
            { "value": "tertiary", "label": "Tertiary" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideout Contact"
    }
  ]
}
{% endschema %}
