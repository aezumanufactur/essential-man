{%- comment -%}
--------------------------------------
assign section settings to variables
--------------------------------------
{%- endcomment -%}

{% render 'style-tags__section', asset_file_name: "mfr-product__top.css" %}

{%- liquid
  assign section_id = section.settings.custom_id | default: section.id
  assign custom_class = section.settings.custom_class
  assign suffix_class = template.suffix | prepend: 'product-top__'  | default: 'product-top__default'
  assign grid_gutter = section.settings.grid_gutter
  assign metafields = product.metafields.mfr_fields
  assign text = section.blocks | where: "type", "text"
  assign buttons = section.blocks | where: "type", "button"

  assign variant = product.selected_or_first_available_variant
  assign variant_size = product.variants | size

  assign product_addon = section.blocks | where: "type", "product_addon"
  assign product_addon_size = product_addon | size

  assign product_benefits = section.settings.product_benefits
  assign product_form_id = "product-form-" | append: block.id | append: product.id
-%}

{% render 'renderer__color-scheme', name: "section", color_scheme: section.settings.color_scheme, selector: ".shopify-section", section_id: section_id %}

{% capture spacer %}
  --top-spacing-mobile: {{ section.settings.top_spacing_mobile | default: 100}}px;
  --bottom-spacing-mobile: {{ section.settings.bottom_spacing_mobile | default: 100 }}px;
  --top-spacing-desktop: {{ section.settings.top_spacing_desktop | default: 100 }}px;
  --bottom-spacing-desktop: {{ section.settings.bottom_spacing_desktop | default: 100 }}px;
{% endcapture %}

{% render 'section__settings-styles' %}

<section 
  class="mfr-product__top background {{ suffix_class }} {{ custom_class }} {{ grid_gutter }}" 
  id="{{ section_id }}"
  data-mfr-product-top>
  <div class="section-spacer relative z-[3] pt-[var(--top-spacing-mobile)] pb-[var(--bottom-spacing-mobile)] large:pt-[var(--top-spacing-desktop)] large:pb-[var(--bottom-spacing-desktop)] {{ grid_gutter }}" style="{{ spacer }}">
    <div class="relative px-[var(--grid-container-padding-mobile)] z-[1] mx-auto w-full max-w-container-md large:px-[var(--grid-container-padding-desktop)]">
      <div class="alignment-helper product-top flex flex-row flex-wrap">
        <div
          class="product-top__media carousel flex justify-center items-start w-full min-w-0 large:w-1/2"
          data-mfr-sticky-container>
          {% render 'product-top__images-carousel',
            product: product,
            section_id: section_id,
            product_benefits: product_benefits %}
        </div>

        <div class="section-content overflow-hidden flex justify-center items-start transition-all large:pt-[2.875rem] large:pr-[1.25rem] large:pb-0 large:pl-[4.6875rem] w-full min-w-0 large:w-1/2"
          x-data='MFRProductTop()'
          :class='formLoading ? "is-loading" : ""'>
          <script type="application/json"
            class="variant-json-script"
            data-selected-variable
            data-replace="{{ section.id }}-selected-variant">
            {{ product.selected_or_first_available_variant | json }}
          </script>
          <div class="inner flex justify-center items-start flex-col max-w-[46.875rem] w-full mx-auto large:max-w-none">
            {%- for block in section.blocks -%}
              {% case block.type %}
                {%- when "@app" -%}
                  {% render block %}
              
                {%- when "icon" -%}
                  {% render 'renderer__block-icon', block: block %} 
                  
                {%- when "small_text" -%}
                  {% if block.settings.text != blank %}
                    <div class="product-top__detail">
                      {{ block.settings.text }}
                    </div>
                  {% endif %}

                {%- when "heading" -%}
                  <div class="section-title {{ block.settings.header_style }} mb-[0.6875rem] leading-[1.056em] large:leading-[1.087em] xlarge:w-4/5"
                    data-split-text="fadeUp">
                    {% assign product_title = product.metafields.mfr_fields.nice_title | default: product.title %}
                    {{ block.settings.heading | default: product_title }}
                  </div>

                {%- when "text" -%}
                  {% assign text = block.settings.text | strip_html %}
                  {% if text != blank %}
                    {% render "renderer__block-text", block: block %}
                  {% endif %}

                {% when "submit_button" %}
                  {% render 'product-top__submit', 
                    block: block,
                    product_form_id: product_form_id %}

                {% when "subscription_option" %}
                  {% render 'product-form__subscription-selector', block: block, product: product, product_form_id: product_form_id %}

                {%- when "variant_selector" -%}
                  {% render 'product-form__variant-selector' %}

                {%- when "product_description" -%}
                  {% assign product_description = product.metafields.mfr_fields.nice_description | metafield_tag %}
                  {% assign product_description = product_description | default: product.description %}
                  {% if product_description != blank %}
                    {% render 'product-top__description', product_description: product_description %}
                  {% endif %}

                {%- when "product_rating" -%}
                  {%- liquid
                    assign total_reviews = block.settings.total_reviews
                    assign rating = block.settings.ratings
                    assign label = block.settings.label
                  -%}
                  {% render 'component__product-rating', rating: rating, total_reviews: total_reviews, label: label %}
                  
                {%- when "accordion" -%}
                  {%- capture accordion_content -%}
                    {{ block.settings.content }}
                  {%- endcapture -%}

                  {% render 'mfr-component__accordion',
                    block_id: block.id,
                    class: "product-top__accordion border border-[rgba(0,0,0,0.1)] rounded-[1.25rem] [&:not(:last-child)]:mb-3",
                    trigger_class: "product-top__accordion-label text-[1.125rem] leading-[1.056em] font-semibold tracking-[-0.011875rem] p-[1.125rem_1.4375rem] large:p-[1.3125rem_1.4375rem]",
                    trigger_label: block.settings.title,
                    content_class: "product-top__accordion-content px-[1.4375rem]",
                    content: accordion_content %}

                {%- when "price" -%}
                  <div class="product-top__price [&:not(:last-child)]:mb-[1.0625rem] large:[&:not(:last-child)]:mb-[1.4375rem]" data-inview>
                    <div class="product-top__price-inner flex flex-col items-stretch transition-all">
                      <div class="product-top__price-header flex items-center text-[1.3125rem] leading-[0.905em] font-medium">
                        <template x-if='currentCompareAtPrice'>
                          <span
                            class="product-top__price-old-value line-through opacity-30 text-[1.25rem] leading-[1.1em] font-medium tracking-[-0.03125rem] mr-[0.3125rem] large:text-[1.75rem] large:leading-[1em] large:tracking-[-0.04375rem] large:mr-[0.75rem]"
                            x-text='currentCompareAtPrice'></span>
                        </template>
                        <span
                          class="product-top__price-value text-[1.25rem] leading-[1.1em] font-medium tracking-[-0.03125rem] mr-[0.3125rem] large:text-[1.75rem] large:leading-[1em] large:tracking-[-0.04375rem] large:mr-[0.75rem]"
                          x-text='currentPriceValue'>
                          {{ variant.price | money }}
                        </span>
                        {% if variant.compare_at_price != blank and variant.compare_at_price > 0 and variant.compare_at_price > variant.price %}
                          <span class="product-top__price-badge text-[0.875rem] leading-[1.214em] uppercase min-h-[1.4375rem] py-[0.3125rem] px-[0.5rem] text-white bg-[#F32424] rounded-[0.375rem]">
                            Sale
                          </span>
                        {% endif %}
                      </div>
                    </div>
                  </div>

                {%- when "divider" -%}
                  <span class="product-top__divider w-full h-[1.5px] bg-current block [opacity:var(--opacity)] [&:not(:last-child)]:mb-[var(--spacing-mobile)] large:[&:not(:last-child)]:mb-[var(--spacing-desktop)]"
                    style="
                      --opacity: {{ block.settings.opacity | divided_by: 100.00 }};
                      --spacing-mobile: {{ block.settings.spacing_mobile }}px;
                      --spacing-desktop: {{ block.settings.spacing_mobile }}px;
                    "></span>

                {%- when "related_products" -%}
                  {% if block.settings.product_list != blank %}
                    <div class="product-top__related-products [&:not(:last-child)]:mb-[1.625rem] large:[&:not(:last-child)]:mb-[2.3125rem]">
                      {% if block.settings.label != blank %}
                        <p class="product-top__related-products-label text-[0.875rem] leading-[1.214em] font-semibold uppercase m-0 opacity-40 [&:not(:last-child)]:mb-5">
                          {{ block.settings.label }}
                        </p>
                      {% endif %}

                      {% if block.settings.product_list != blank %}
                        <ul class="product-top__related-products-inner flex flex-wrap justify-start content-start gap-2 list-none m-0 large:gap-[0.8125rem] [&:not(:last-child)]:mb-[1.625rem] large:[&:not(:last-child)]:mb-[2.3125rem]">
                          {%- for entry in block.settings.product_list -%}
                            {%- liquid
                              assign fields = entry.metafields.mfr_fields
                              assign image = fields.small_product_card_image | default: entry.media[0]
                              assign big_text = fields.small_product_card_big_text
                              assign regular_text = fields.small_product_card_regular_text
                              assign small_text = fields.small_product_card_small_text
    
                              if entry.id == product.id
                                assign current_product = true
                              else
                                assign current_product = false
                              endif
                              if big_text == blank and regular_text == blank and small_text == blank
                                assign small_text = entry.title
                              endif
                            -%}

                            <li style="--light-color: {{ fields.product_color_light | default: '#B6E7F9' }};">
                              <a href="{%- unless current_product -%}{{ entry.url }}{%- else -%}#{%- endunless -%}"
                                class="{%- if current_product -%}is-active no-hover{%- endif -%}"
                                aria-label="{{ big_text }} {{ regular_text }} {{ small_text }}"
                                title="{{ big_text }} {{ regular_text }} {{ small_text }}">

                                <div class="product-top__related-products-image w-full aspect-[82/70] flex justify-center items-center rounded-[0.375rem] [&:not(:last-child)]:mb-[0.1875rem] large:[&:not(:last-child)]:mb-[0.6875rem]">
                                  {% assign default_alt = "maybe an image about " | append: entry.title %}
                                  {% assign alt = image.alt | default: default_alt %}
                                  {% render 'component__lazyload-image', image: image, width: 240, alt: alt, widths: "240" %}
                                </div>

                                <div class="product-top__related-products-texts flex flex-col items-center justify-start text-center">
                                  {% if big_text != blank %}
                                    <p class="big-text text-[1.375rem] leading-[1.364em] font-normal m-0 opacity-60 transition-all large:text-[1.5rem] large:leading-[1.25em] [&:not(:last-child)]:large:mb-0.5">{{ big_text }}</p>
                                  {% endif %}

                                  {% if regular_text != blank %}
                                    <p class="regular-text text-[1.125rem] leading-[1.364em] font-normal m-0 opacity-60 transition-all large:text-[1.3125rem] large:leading-[1.048em] [&:not(:last-child)]:large:mb-0.5">{{ regular_text }}</p>
                                  {% endif %}

                                  {% if small_text != blank %}
                                    <p class="mini-text text-[0.875rem] leading-[1.214em] font-normal m-0 block opacity-40 large:text-[1rem] large:leading-[1.063em]">{{ small_text }}</p>
                                  {% endif %}
                                </div>
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {% endif %}
                    </div>
                  {% endif %}

                {%- when "product_rtbs" -%}
                  {% if block.settings.product_rtbs != blank %}
                    <ul class="product-top__rtbs flex flex-wrap justify-start content-start gap-[0.4375rem] list-none m-0 w-full large:gap-[0.6875rem] [&:not(:last-child)]:mb-8 large:[&:not(:last-child)]:mb-[1.5625rem]">
                      {%- for entry in block.settings.product_rtbs -%}
                        <li>
                          <div class="product-top__rtb flex flex-col justify-start items-center p-[0.875rem_0.75rem_0.75rem] text-center w-full bg-[#f3f3f3] rounded-lg large:p-[1.3125rem_0.625rem]">
                            {% if entry.icon != blank %}
                              <div class="product-top__rtb-image w-full max-w-[2.6875rem] h-10 flex justify-center items-center [&:not(:last-child)]:mb-2 large:[&:not(:last-child)]:mb-[1.0625rem]">
                                {% assign default_alt = "maybe an image about " | append: entry.label %}
                                {% assign alt = entry.icon.alt | default: default_alt %}

                                {% render 'component__lazyload-image', image: entry.icon, alt: alt, width: 240, widths: "240" %}
                              </div>
                            {% endif %}

                            {% if entry.label != blank %}
                              <p class="product-top__rtb-text text-[0.75rem] leading-[1em] font-medium tracking-[-0.008125rem] block m-0 large:text-[0.875rem] large:tracking-[-0.009375rem]">
                                {{ entry.label }}
                              </p>
                            {% endif %}
                          </div>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {% endif %}

                {%- when "product_addon" -%}
                  {% assign main_top_form_id = "product_form_" | append: product.id %}
                  {% render 'product-top__addon', 
                    block: product_addon, 
                    main_form_id: main_top_form_id, 
                    addons_title: block.settings.text, 
                    use_variant_name: block.settings.use_variant_name %}

                {%- when "product_title_excerpt" -%}
                  <div class="product-top__title-excerpt flex [justify-content:var(--justify-content-desktop)] content-start flex-wrap [column-gap:0.625rem] [row-gap:0.875rem] w-full large:[column-gap:11.23%] large:[row-gap:1.125rem] [&:not(:last-child)]:mb-[1.875rem] large:[&:not(:last-child)]:mb-[1.1875rem]"
                    data-stagger-inview=".product-top__title-excerpt-badge,.product-top__title-excerpt-excerpt">
                    {%- if block.settings.title != blank -%}
                      <p class="product-top__title-excerpt-title {{ block.settings.header_style }} min-w-[55%] leading-[1.056em] m-0 flex-[1_1_0] large:leading-[1.087em] large:max-w-[74%] xlarge:min-w-[65%] xlarge:max-w-[80%]">
                        {%- assign title = metafields.nice_title | default: product.title -%}
                        {{ block.settings.title 
                          | replace: "[product-title]", title }}
                      </p>
                    {%- endif -%}

                    {%- if block.settings.badge != blank -%}
                      <span class="product-top__title-excerpt-badge hide-for-large text-sm leading-[1.286em] font-extrabold uppercase self-start flex-shrink-0 inline-block py-1.5 px-3 pt-1 bg-[var(--color-accent-2)] text-white rounded-[0.875rem]">
                        {{ block.settings.badge }}
                      </span>
                    {%- endif -%}
                    {%- if block.settings.excerpt != blank or block.settings.badge != blank -%}
                      <div class="product-top__title-excerpt-inner flex justify-stretch content-start flex-wrap">
                        {%- if block.settings.excerpt != blank -%}
                          <p class="product-top__title-excerpt-excerpt {{ block.settings.text_style }} w-4/5 large:w-auto large:flex-[1_1_0] large:max-w-[74%] large:mr-auto xlarge:min-w-[65%]">
                            {{ block.settings.excerpt }}
                          </p>
                        {%- endif -%}

                        {%- if block.settings.badge != blank -%}
                          <span class="product-top__title-excerpt-badge show-for-large text-sm leading-[1.286em] font-extrabold uppercase self-start flex-shrink-0 inline-block py-1.5 px-3 pt-1 bg-[var(--color-accent-2)] text-white rounded-[0.875rem]">
                            {{ block.settings.badge }}
                          </span>
                        {%- endif -%}
                        
                      </div>
                    {%- endif -%}
                  </div>

                {%- when "quantity_selector" -%}
                  {% if product.selected_or_first_available_variant.available and block.settings.beside_add_to_cart == false %}
                    <div class="product-top__quantity-selector flex-shrink-0 flex justify-stretch items-stretch w-1/2 [&:not(:last-child)]:mb-[0.625rem]">
                      {%- render "component__quantity-selector-v2",
                        name: "quantity",
                        min: 1, 
                        max: product.selected_or_first_available_variant.inventory_quantity,
                        product_form_id: product_form_id -%} 
                    </div>
                  {% endif %}

                {%- when "product_benefits" -%}
                  {%- if block.settings.product_benefits != blank -%}
                    <ul class="product-top__product-benefits flex flex-col justify-stretch items-stretch w-full p-0 m-0 list-none overflow-hidden large:max-w-[26.3125rem] [&:not(:last-child)]:mb-[3.125rem]"
                      data-stagger-inview="li">
                      {%- for product_benefit in block.settings.product_benefits -%}
                        <li class="leading-[1.333em] font-normal tracking-[-0.03rem] w-full pb-[0.625rem] border-b border-current flex justify-start items-start gap-[1.0625rem] transition-all large:pb-[0.53125rem] [&:not(:last-child)]:mb-[0.625rem] large:[&:not(:last-child)]:mb-[0.53125rem]">
                          {%- capture svg_code -%}
                            <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="33" height="33">
