{%- comment -%}
assign section settings to variables
{%- endcomment -%}

{% render 'style-tags__section', asset_file_name: "mfr-core__featured-product.css" %}
{%- assign custom_class = section.settings.custom_class -%}
{%- assign section_id = section.settings.custom_id | default: section.id -%}
{%- assign product = section.settings.product -%}
{%- assign variant = product.selected_or_first_available_variant -%}

<section class="mfr-core__featured-product {{ custom_class }}" id="{{ section_id }}">
  <div class="featured-product">

    {%- if section.settings.heading != blank -%}
      <div class="featured-product__title border-t border-b border-[#1e1b22] bg-[#d5d1c8] px-[20px] large:px-[30px] py-[20px] large:py-[30px] overflow-hidden">
        <h2 class="featured-product__heading [font-family:var(--font-heading-h1)] text-[48px] large:text-[90px] font-[400] leading-none tracking-[-0.9px] uppercase text-[#1e1b22] w-full">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    <div class="featured-product__container bg-[#d5d1c8] flex flex-col large:flex-row large:items-stretch overflow-hidden w-full">

      <div class="featured-product__media aspect-[932/710] large:aspect-auto large:flex-1 overflow-hidden relative bg-[#c4bfb3] large:border-r large:border-[#1e1b22]">
        {%- if section.settings.image != blank -%}
          <div class="absolute inset-0">
            {%- render "component__lazyload-image",
              image: section.settings.image,
              width: 1200,
              class: "w-full min-h-full block object-cover" -%}
          </div>
        {%- else -%}
          <div class="w-full h-full bg-[#c4bfb3]"></div>
        {%- endif -%}
      </div>

      {%- if product != blank -%}
        <div class="featured-product__content flex flex-col justify-between gap-[60px] large:gap-[123px] items-start px-[20px] large:px-[30px] py-[40px] large:py-[50px] large:w-[35%]">

          <div class="featured-product__text relative flex flex-col gap-[4px] items-start w-full">

            <div class="featured-product__product-info flex flex-col gap-[32px] items-start w-full">

              {%- if section.settings.product_subtitle != blank -%}
                <p class="featured-product__subtitle [font-family:var(--font-heading-h1)] text-[16px] font-[700] leading-[1.5] uppercase text-[#1e1b22]">
                  {{ section.settings.product_subtitle }}
                </p>
              {%- endif -%}

              <div class="featured-product__product-details flex flex-col gap-[20px] items-start w-full">
                <h3 class="featured-product__product-title [font-family:var(--font-heading-h1)] text-[32px] large:text-[46px] font-[500] leading-none uppercase text-[#1e1b22]">
                  {{ product.title }}
                </h3>

                <div class="featured-product__price-row flex flex-wrap gap-[12px] items-center">
                  {%- if variant.compare_at_price > variant.price -%}
                    <span class="featured-product__compare-price [font-family:var(--custom-font-name-2)] text-[14px] font-[700] leading-[1.5] uppercase text-[#1e1b22] opacity-30 line-through">
                      {{ variant.compare_at_price | money }}
                    </span>
                  {%- endif -%}
                  <span class="featured-product__sale-price [font-family:var(--custom-font-name-2)] text-[14px] font-[700] leading-[1.5] uppercase text-[#1e1b22]">
                    {{ variant.price | money }}
                  </span>
                  {%- if variant.compare_at_price > variant.price -%}
                    {%- assign save_amount = variant.compare_at_price | minus: variant.price | money -%}
                    <span class="featured-product__save-tag [font-family:var(--custom-font-name-2)] text-[12px] font-[700] leading-[20px] uppercase text-[#eeece5] bg-[#d15722] px-[8px] py-[6px] rounded-[5px]">
                      Save {{ save_amount }}
                    </span>
                  {%- endif -%}
                </div>
              </div>

              {%- if product.description != blank -%}
                <div class="featured-product__description [font-family:var(--custom-font-name-2)] text-[14px] font-[700] leading-[1.5] uppercase text-[#1e1b22]">
                  {{ product.description }}
                </div>
              {%- endif -%}

            </div>

            {%- if section.settings.best_value_tag != blank -%}
              <span class="featured-product__best-value-tag absolute top-0 right-0 [font-family:var(--custom-font-name-2)] text-[12px] font-[700] leading-[20px] uppercase text-[#eeece5] text-center bg-[#647949] px-[8px] py-[7px] rounded-[5px]">
                {{ section.settings.best_value_tag }}
              </span>
            {%- endif -%}

          </div>

          <div class="featured-product__benefits flex flex-col gap-[33px] items-start w-full">

            {%- assign benefits_ns = section.settings.benefits_metafield_namespace | default: "custom" -%}
            {%- assign benefits_key = section.settings.benefits_metafield_key | default: "benefits" -%}
            {%- assign benefits = product.metafields[benefits_ns][benefits_key] -%}
            {%- if benefits != blank -%}
              <div class="featured-product__benefits-list flex flex-col gap-[13px] items-start w-full">
                {%- for benefit in benefits.value -%}
                  <div class="featured-product__benefit flex flex-col gap-[12px] items-start w-full">
                    <div class="featured-product__benefit-row flex gap-[12px] items-center w-full">
                      <span class="featured-product__benefit-icon shrink-0 size-[19px]">
                        <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="9.5" cy="9.5" r="9" stroke="#1e1b22" stroke-width="1"/>
                          <path d="M5.5 9.5L8 12L13.5 7" stroke="#1e1b22" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <p class="featured-product__benefit-text [font-family:var(--custom-font-name-2)] text-[14px] font-[700] leading-[18px] uppercase text-[#1e1b22] flex-1 min-w-0">
                        {{ benefit.label }}
                      </p>
                    </div>
                    {%- unless forloop.last -%}
                      <div class="featured-product__benefit-divider w-full border-t border-[#1e1b22] opacity-20"></div>
                    {%- endunless -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- render "component__add-to-cart-button",
              product: product,
              button_class: "w-full justify-center" -%}

          </div>

        </div>
      {%- endif -%}

    </div>

  </div>
</section>


{% schema %}
{
  "name": "Featured Product",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.offcanvas",
      "custom.modals"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Two Products. One system."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Product Subtitle",
      "default": "Powder + Clay"
    },
    {
      "type": "text",
      "id": "best_value_tag",
      "label": "Best Value Badge Text",
      "default": "Best Value"
    },
    {
      "type": "header",
      "content": "Benefits Metafield"
    },
    {
      "type": "text",
      "id": "benefits_metafield_namespace",
      "label": "Namespace",
      "default": "custom",
      "info": "The metafield namespace on the product that holds the benefits list."
    },
    {
      "type": "text",
      "id": "benefits_metafield_key",
      "label": "Key",
      "default": "benefits",
      "info": "The metafield key. Must be a list.metaobject_reference with a 'label' field."
    },
    {
      "type": "header",
      "content": "Attribute Settings"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom ID"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Featured Product"
    }
  ]
}
{% endschema %}
