{%- comment -%}
--------------------------------------
assign section settings to variables
--------------------------------------
{%- endcomment -%}

{% render 'style-tags__section', asset_file_name: "mfr-core__image-video-text-section.css" %}

{%- assign container_width = section.settings.container_width -%}
{%- assign max_width = section.settings.max_width -%}
{%- assign grid_gutter = section.settings.grid_gutter -%}
{%- assign color_theme = section.settings.color_theme -%}
{%- assign custom_class = section.settings.custom_class -%}

{%- assign sc_block = nil -%}
{%- for block in section.blocks -%}
  {%- if block.type == "_section-content" -%}
    {%- assign sc_block = block -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- assign sc_margin_y_mobile = false -%}
{%- assign sc_margin_y_desktop = false -%}
{%- if sc_block and sc_block.settings.enable_margin_settings -%}
  {%- if sc_block.settings.margin_y_mobile -%}{%- assign sc_margin_y_mobile = true -%}{%- endif -%}
  {%- if sc_block.settings.margin_y_desktop -%}{%- assign sc_margin_y_desktop = true -%}{%- endif -%}
{%- endif -%}

{% if section.settings.media_column_size == "one-third" %}
  {% assign media_col = "large:w-1/3" %}
  {% assign content_col = "large:w-2/3" %}
{% elsif section.settings.media_column_size == "half" %}
  {% assign media_col = "large:w-1/2" %}
  {% assign content_col = "large:w-1/2" %}
{% elsif section.settings.media_column_size == "two-thirds" %}
  {% assign media_col = "large:w-2/3" %}
  {% assign content_col = "large:w-1/3" %}
{% endif %}

{%- assign section_id = section.settings.custom_id | default: section.id -%}
{% render 'renderer__color-scheme', name: "section", color_scheme: section.settings.color_scheme, selector: ".shopify-section", section_id: section_id %}

{%- if max_width != 0 and container_width == "" -%}
  {%- capture max_width_style -%}
    style="max-width: {{ max_width }}rem;" 
  {%- endcapture -%}
{%- endif -%}

{% capture spacer %}
  --top-spacing-mobile: {{ section.settings.top_spacing_mobile | default: 100}}px;
  --bottom-spacing-mobile: {{ section.settings.bottom_spacing_mobile | default: 100 }}px;
  --top-spacing-desktop: {{ section.settings.top_spacing_desktop | default: 100 }}px;
  --bottom-spacing-desktop: {{ section.settings.bottom_spacing_desktop | default: 100 }}px;
{% endcapture %}

{% render 'section__settings-styles' %}

<style>
  #{{ section_id }} {
    --vertical-alignment: {{ section.settings.vertical_alignment | default: 'center' }};
  }
  @media (min-width: 1024px) {
    {%- if section.settings.vertical_alignment == 'space-between' -%}
      #{{ section_id }} .alignment-helper { align-content: space-between; }
    {%- else -%}
      #{{ section_id }} .alignment-helper { align-items: {{ section.settings.vertical_alignment | default: 'center' }}; }
    {%- endif -%}
  }
</style>

<section class="mfr-core__image-video-text-section {{ custom_class }} {{ grid_gutter }}" id="{{ section_id }}"
  data-desktop-layout="{{ section.settings.text_side_desktop }}"
  data-mobile-layout="{{ section.settings.text_side_mobile }}">
  <div class="section-spacer background {{ grid_gutter }} relative z-[3] pt-[var(--top-spacing-mobile)] pb-[var(--bottom-spacing-mobile)] large:pt-[var(--top-spacing-desktop)] large:pb-[var(--bottom-spacing-desktop)]" style="{{ spacer }}">
    <div class="grid-container{% if container_width == 'full' %} full max-w-none px-0{% else %} mx-auto max-w-[var(--grid-container-max-width)] px-[var(--grid-container-padding-mobile)] large:px-[var(--grid-container-padding-desktop)]{% endif %} w-full relative z-[1]" {{ max_width_style }}>
      <div class="alignment-helper {{ color_theme }} flex flex-row flex-wrap [justify-content:var(--justify-content-mobile)] [text-align:var(--text-align-mobile)] large:[justify-content:var(--justify-content-desktop)] large:[text-align:var(--text-align-desktop)]">
        <div class="section-media w-full min-w-0 {{ media_col }} flex
          {%- if section.settings.text_side_desktop == 'text-left' %} large:order-2 large:pl-[3.75rem]{%- else %} large:order-1 large:pr-[3.75rem]{%- endif %}
          {%- if section.settings.text_side_mobile == 'text-top' %} order-2{%- else %} order-1 mb-[3.75rem]{%- endif %}
          {%- if section.settings.enable_sticky %} [&[data-mfr-sticky-container]]:large:self-stretch{%- endif %}"
          {% if section.settings.enable_sticky %}data-mfr-sticky-container=".image-video-text__carousel-inner"{% endif %}>
          {%- content_for "block", type: "_image-video-text__carousel", id: "image-video-text-carousel" -%}
        </div>
        <div class="section-content w-full min-w-0 {{ content_col }} relative z-[2] flex [align-items:inherit] [justify-content:inherit] flex-wrap gap-x-[1.875rem]
          {%- unless sc_margin_y_mobile %} mb-[5rem]{%- endunless %} last:mb-0
          {%- unless sc_margin_y_desktop %} large:mb-[5.625rem]{%- endunless %}
          large:gap-x-[3.75rem] [&>.shopify-block:not(:last-child)]:mb-[0.9375rem] large:[&>.shopify-block:not(:last-child)]:mb-[1.875rem] empty:hidden [&_.accordion__wrapper]:w-full [&_.accordion__wrapper]:max-w-[34.375rem]
          {%- if section.settings.text_side_desktop == 'text-left' %} large:order-1{%- else %} large:order-2{%- endif %}
          {%- if section.settings.text_side_mobile == 'text-top' %} order-1{%- unless sc_margin_y_mobile %} mb-[3.75rem]{%- endunless %}{%- else %} order-2{%- endif %}"
          data-stagger-inview=".section-icon__wrapper, .section-content__small-text, .section-content__text, .section-content__button, .accordion__wrapper, .mfr-list__wrapper li">
          {%- content_for "blocks" -%}
        </div>
      </div>
    </div>
  
    {%- render 'component__gradient-bg-styles' -%}
  </div>
  {%- render 'component__section-dividers', is_video_background: true -%}
  {% content_for "block", type: "_accent-graphics", id: "accent-graphics" %}
</section>


