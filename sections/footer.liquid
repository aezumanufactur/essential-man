{% comment %} {% render 'style-tags__section', asset_file_name: "footer.css", lazyload: true %} {% endcomment %}
{% render 'renderer__color-scheme', name: "footer", color_scheme: section.settings.color_scheme, selector: ".footer" %}
{% assign appear_on = section.settings.appear_on | newline_to_br | strip_newlines | split: '<br />' %}

{% assign embed = section.blocks | where: "type", "embed" | first %}
{% assign menus = section.blocks | where: "type", "menu" %}
{% assign big_menus = section.blocks | where: "type", "big_menu" %}

{% if appear_on == blank or appear_on contains template %}
  <style>
    #footer {
      --footer-overlay-mobile: url('{{ 'footer__overlay-mobile.png' | asset_img_url: 'master' }}');
      --footer-overlay-desktop: url('{{ 'footer__overlay-desktop.png' | asset_img_url: 'master' }}');
    }
  </style>
  <div class="grid-container w-full flex flex-row flex-wrap" data-inview>
    <div class="footer__contents flex flex-col justify-stretch transition-all large:flex-row large:justify-between large:flex-wrap w-full min-w-0">
      {% if embed != blank %}
        <div class="footer__embed flex flex-col pb-[2.0625rem] border-b border-[rgba(139,147,167,0.4)] w-full [&:not(:last-child)]:mb-[0.25rem] large:flex-shrink-0 large:items-start large:justify-between large:flex-row large:pb-[3.125rem] large:[&:not(:last-child)]:mb-[1.3125rem]"
          data-stagger-inview=".footer__embed-icon,.footer__embed-heading,.footer__embed-caption,.footer__embed-code">
          <div class="footer__embed-header flex flex-col items-start justify-center gap-[0.25rem] w-[80%] large:w-1/4 large:min-w-[20.75rem]">
            {% if embed.settings.heading != blank %}
              <p class="footer__embed-heading regular">
                {{ embed.settings.heading }}
              </p>
            {% endif %}
            {% if embed.settings.caption != blank %}
              <p class="footer__embed-caption small">
                {{ embed.settings.caption }}
              </p>
            {% endif %}
          </div>
          {% if embed.settings.embed_code != blank %}
            <div class="footer__embed-code w-full large:w-[41%]">
              {{ embed.settings.embed_code | newline_to_br }}
            </div>
          {% endif %}
        </div>
      {% endif %}
      
      {% if big_menus != blank %}
        <div class="footer__big-menus flex flex-col justify-stretch items-stretch w-full [&:not(:last-child)]:mb-[0.25rem] large:flex-row large:justify-start large:items-start large:flex-wrap large:gap-[3.75rem] large:w-[59%] large:[&:not(:last-child)]:mb-0">
          {% for big_menu in big_menus %}
            <div class="footer__big-menu border-b border-[rgba(139,147,167,0.4)] pb-[1.625rem] large:border-none large:pb-0">
              <p class="footer__big-menu-label">
                {{ big_menu.settings.label }}
              </p>
              <ul class="footer__big-menu-list flex flex-col items-stretch justify-stretch list-none m-0" data-stagger-inview="li">
                {% for link in big_menu.settings.menu.links %}
                  <li>
                    <a href="{{ link.url }}"
                      class="h5"
                      aria-label="{{ link.title }}"
                      title="{{ link.title }}">
                      <span>{{ link.title }}</span>
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if menus != blank %}
        <template
          x-data="{ isSmallScreen: window.outerWidth <= 1023 }" 
          x-init="
            window.addEventListener('resize', () => {
              isSmallScreen = window.outerWidth <= 1023;
            });
          "
          x-if="isSmallScreen">
          <div class="footer__menus flex flex-col justify-stretch items-stretch w-full large:flex-row large:justify-start large:items-start large:flex-wrap large:gap-[3.75rem] large:w-[41%]">
            {% for menu in menus %}
              {%- capture accordion_content -%}
                {% if menu.settings.menu != blank %}
                  <ul class="footer__menu-list flex flex-col items-stretch justify-stretch list-none m-0">
                    {% for link in menu.settings.menu.links %}
                      <li>
                        <a href="{{ link.url }}"
                          aria-label="{{ link.title }}"
                          title="{{ link.title }}">
                          <span>{{ link.title }}</span>
                        </a>
                      </li>
                    {% endfor %}
                    {% if menu.settings.show_accessibe_trigger %}
                      <li>
                        <a href="#" data-acsb-custom-trigger="true"
                          title="Accessibility"
                          aria-label="Accessibility">
                          Accessibility
                        </a>
                      </li>
                    {% endif %}
                  </ul>
                {% endif %}
              {%- endcapture -%}
              {% render 'mfr-component__accordion',
                block_id: menu.id,
                class: "footer__menu",
                trigger_class: "footer__menu-label",
                trigger_label: menu.settings.heading,
                content_class: "",
                content: accordion_content %}
            {% endfor %}
          </div>
        </template>
        <template
          x-data="{ isSmallScreen: window.outerWidth <= 1023 }" 
          x-init="
            window.addEventListener('resize', () => {
              isSmallScreen = window.outerWidth <= 1023;
            });
          "
          x-if="!isSmallScreen">
          <div class="footer__menus flex flex-col justify-stretch items-stretch w-full large:flex-row large:justify-start large:items-start large:flex-wrap large:gap-[3.75rem] large:w-[41%]">
            {% for menu in menus %}
              <div class="footer__menu">
                <p class="footer__menu-label">
                  {{ menu.settings.heading }}
                </p>
                <ul class="footer__menu-list">
                  {% for link in menu.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}"
                        aria-label="{{ link.title }}"
                        title="{{ link.title }}">
                        <span>{{ link.title }}</span>
                      </a>
                    </li>
                  {% endfor %}
                  {% if menu.settings.show_accessibe_trigger %}
                    <li>
                      <a href="#" data-acsb-custom-trigger="true"
                        title="Accessibility"
                        aria-label="Accessibility">
                        Accessibility
                      </a>
                    </li>
                  {% endif %}
                </ul>
              </div>
            {% endfor %}
          </div>
        </template>
      {% endif %}
    </div>
  </div>
{% else %}
  <style>
    #shopify-section-{{- section.id -}} {
      visibility: hidden;
      display: none;
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Footer",
  "class": "footer__main",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Color Schemes Settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme_1",
      "label": "Color Scheme",
      "info": "This will be the color scheme of the footer initially."
    },
    {
      "type": "header",
      "content": "Visibility Settings"
    },
    {
      "type": "textarea",
      "id": "appear_on",
      "label": "Appear Only On:",
      "info": "Separated by newline. Insert template.suffix. Example: product or product.bundles"
    }
  ],
  
  "blocks": [
    {
      "type": "embed",
      "name": "Embed",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Lorem, ipsum dolor."
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Lorem ipsum dolor sit amet consectetur adipisicing elit"
        },
        {
          "type": "textarea",
          "id": "embed_code",
          "label": "Embed Code"
        }
      ]
    },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "checkbox",
          "id": "show_accessibe_trigger",
          "label": "Show Accessibe Trigger",
          "default": false
        },
      ]
    },
    {
      "type": "big_menu",
      "name": "Big Menu",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Lorem ipsum"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
